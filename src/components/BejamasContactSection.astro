---
import { TRANSLATIONS } from '../consts';

const t = TRANSLATIONS.zh;
---

<section class="bejamas-section bejamas-bg-gradient" id="contact">
  <div class="bejamas-container">
    <div class="bejamas-section-header bejamas-text-center">
      <h2 class="bejamas-title-2xl bejamas-heading">{t.contactTitle}</h2>
      <p class="bejamas-subtitle bejamas-mt-2">立即联系我们，获取专业的物流解决方案</p>
    </div>
    
    <div class="bejamas-contact-grid">
      <div class="bejamas-contact-info">
        <div class="bejamas-contact-card">
          <div class="bejamas-contact-icon bejamas-bg-blue-100">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M21 10C21 17 12 23 12 23C12 23 3 17 3 10C3 7.61305 3.94821 5.32387 5.63604 3.63604C7.32387 1.94821 9.61305 1 12 1C14.3869 1 16.6761 1.94821 18.364 3.63604C20.0518 5.32387 21 7.61305 21 10Z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 13C13.6569 13 15 11.6569 15 10C15 8.34315 13.6569 7 12 7C10.3431 7 9 8.34315 9 10C9 11.6569 10.3431 13 12 13Z" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <div class="bejamas-contact-content">
            <h4 class="bejamas-title-md">办公地址</h4>
            <p class="bejamas-text-base">哈萨克斯坦 · 阿拉木图市</p>
            <p class="bejamas-text-sm bejamas-text-muted">专业物流园区A座3楼</p>
          </div>
        </div>
        
        <div class="bejamas-contact-card">
          <div class="bejamas-contact-icon bejamas-bg-green-100">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M22 16.92V19.92C22 20.52 21.49 21.01 20.88 20.91C19.93 20.75 18.94 20.55 18.01 20.26C15.22 19.36 12.83 17.38 11.11 14.67C9.97998 12.87 9.17998 10.84 8.76998 8.69C8.30998 6.25 8.62998 3.77 9.67998 1.59C9.86998 1.19 10.33 0.950001 10.76 1.070001C11.75 1.350001 12.7 1.75 13.6 2.250001C14.03 2.500001 14.2 3.050001 13.97 3.480001L12.63 5.920001C12.39 6.360001 12.55 6.930001 12.98 7.200001C13.85 7.760001 14.61 8.450001 15.24 9.240001C15.73 9.850001 15.73 10.72 15.24 11.33C14.61 12.12 13.85 12.81 12.98 13.37C12.55 13.64 12.39 14.21 12.63 14.65L13.97 17.09C14.2 17.52 14.03 18.07 13.6 18.32C12.7 18.82 11.75 19.22 10.76 19.5C10.33 19.62 9.86998 19.38 9.67998 18.98" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="bejamas-contact-content">
            <h4 class="bejamas-title-md">联系电话</h4>
            <p class="bejamas-text-base">+7 (777) 123-45-67</p>
            <p class="bejamas-text-sm bejamas-text-muted">24/7 客户服务热线</p>
          </div>
        </div>
        
        <div class="bejamas-contact-card">
          <div class="bejamas-contact-icon bejamas-bg-purple-100">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4 4H20C21.1 4 22 4.9 22 6V18C22 19.1 21.1 20 20 20H4C2.9 20 2 19.1 2 18V6C2 4.9 2.9 4 4 4Z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M22 6L12 13L2 6" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <div class="bejamas-contact-content">
            <h4 class="bejamas-title-md">电子邮箱</h4>
            <p class="bejamas-text-base">info@hpf.kz</p>
            <p class="bejamas-text-sm bejamas-text-muted">商务合作与咨询</p>
          </div>
        </div>
        
        <div class="bejamas-contact-card">
          <div class="bejamas-contact-icon bejamas-bg-yellow-100">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 21C16.9706 21 21 16.9706 21 12C21 7.02944 16.9706 3 12 3C7.02944 3 3 7.02944 3 12C3 16.9706 7.02944 21 12 21Z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 6V12L16 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="bejamas-contact-content">
            <h4 class="bejamas-title-md">工作时间</h4>
            <p class="bejamas-text-base">周一至周五 9:00-18:00</p>
            <p class="bejamas-text-sm bejamas-text-muted">周末提供紧急服务</p>
          </div>
        </div>
      </div>
      
      <div class="bejamas-contact-form">
        <form class="bejamas-form">
          <div class="bejamas-form-group">
            <label for="name" class="bejamas-form-label">姓名</label>
            <input type="text" id="name" class="bejamas-input" placeholder="请输入您的姓名" required />
          </div>
          
          <div class="bejamas-form-group">
            <label for="email" class="bejamas-form-label">邮箱</label>
            <input type="email" id="email" class="bejamas-input" placeholder="请输入您的邮箱" required />
          </div>
          
          <div class="bejamas-form-group">
            <label for="phone" class="bejamas-form-label">电话</label>
            <input type="tel" id="phone" class="bejamas-input" placeholder="请输入您的联系电话" />
          </div>
          
          <div class="bejamas-form-group">
            <label for="company" class="bejamas-form-label">公司名称</label>
            <input type="text" id="company" class="bejamas-input" placeholder="请输入您的公司名称" />
          </div>
          
          <div class="bejamas-form-group">
            <label for="service" class="bejamas-form-label">服务类型</label>
            <select id="service" class="bejamas-input">
              <option value="">请选择服务类型</option>
              <option value="general">一般物流咨询</option>
              <option value="custom">定制解决方案</option>
              <option value="quote">获取报价</option>
              <option value="support">技术支持</option>
            </select>
          </div>
          
          <div class="bejamas-form-group">
            <label for="message" class="bejamas-form-label">留言内容</label>
            <textarea id="message" class="bejamas-input bejamas-textarea" rows="4" placeholder="请详细描述您的需求..."></textarea>
          </div>
          
          <button type="submit" class="bejamas-button bejamas-button-primary bejamas-w-full">
            发送咨询
          </button>
        </form>
      </div>
    </div>
    
    <div class="bejamas-contact-map">
      <div class="bejamas-map-placeholder">
        <div class="bejamas-map-content">
          <h4 class="bejamas-title-md">我们的服务网络</h4>
          <p class="bejamas-text-base bejamas-text-muted">覆盖中国主要城市与哈萨克斯坦全境</p>
          <div class="bejamas-map-locations">
            <div class="bejamas-location">
              <span class="bejamas-location-marker"></span>
              <span>中国 · 上海</span>
            </div>
            <div class="bejamas-location">
              <span class="bejamas-location-marker"></span>
              <span>中国 · 广州</span>
            </div>
            <div class="bejamas-location">
              <span class="bejamas-location-marker"></span>
              <span>哈萨克斯坦 · 阿拉木图</span>
            </div>
            <div class="bejamas-location">
              <span class="bejamas-location-marker"></span>
              <span>哈萨克斯坦 · 努尔苏丹</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bejamas-contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--bejamas-space-12);
    margin-bottom: var(--bejamas-space-12);
  }
  
  @media (min-width: 1024px) {
    .bejamas-contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  
  .bejamas-contact-info {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--bejamas-space-6);
  }
  
  @media (min-width: 640px) {
    .bejamas-contact-info {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  .bejamas-contact-card {
    background-color: var(--bejamas-color-surface);
    border: 1px solid var(--bejamas-color-border);
    border-radius: var(--bejamas-radius-lg);
    padding: var(--bejamas-space-6);
    display: flex;
    align-items: flex-start;
    gap: var(--bejamas-space-4);
    transition: all var(--bejamas-transition-base);
  }
  
  .bejamas-contact-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--bejamas-shadow-md);
  }
  
  .bejamas-contact-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--bejamas-radius-md);
    color: var(--bejamas-color-accent);
    flex-shrink: 0;
  }
  
  .bejamas-contact-content {
    flex: 1;
  }
  
  .bejamas-form {
    display: flex;
    flex-direction: column;
    gap: var(--bejamas-space-4);
  }
  
  .bejamas-form-group {
    display: flex;
    flex-direction: column;
    gap: var(--bejamas-space-2);
  }
  
  .bejamas-form-label {
    font-weight: 500;
    color: var(--bejamas-color-text);
    font-size: var(--bejamas-text-sm);
  }
  
  .bejamas-input {
    padding: var(--bejamas-space-3) var(--bejamas-space-4);
    border: 1px solid var(--bejamas-color-border);
    border-radius: var(--bejamas-radius-md);
    background-color: var(--bejamas-color-bg);
    color: var(--bejamas-color-text);
    font-size: var(--bejamas-text-base);
    transition: all var(--bejamas-transition-base);
  }
  
  .bejamas-input:focus {
    outline: none;
    border-color: var(--bejamas-color-accent);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
  }
  
  .bejamas-textarea {
    resize: vertical;
    min-height: 100px;
  }
  
  .bejamas-contact-map {
    background-color: var(--bejamas-color-surface);
    border: 1px solid var(--bejamas-color-border);
    border-radius: var(--bejamas-radius-xl);
    overflow: hidden;
  }
  
  .bejamas-map-placeholder {
    height: 200px;
    background: linear-gradient(135deg, var(--bejamas-color-bg) 0%, var(--bejamas-color-surface) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .bejamas-map-content {
    text-align: center;
    padding: var(--bejamas-space-6);
  }
  
  .bejamas-map-locations {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--bejamas-space-4);
    margin-top: var(--bejamas-space-4);
  }
  
  .bejamas-location {
    display: flex;
    align-items: center;
    gap: var(--bejamas-space-2);
    font-size: var(--bejamas-text-sm);
  }
  
  .bejamas-location-marker {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--bejamas-color-accent);
  }
  
  /* Color variants */
  .bejamas-bg-blue-100 {
    background-color: rgba(59, 130, 246, 0.1);
    color: var(--bejamas-color-blue-600);
  }
  
  .bejamas-bg-green-100 {
    background-color: rgba(16, 185, 129, 0.1);
    color: var(--bejamas-color-green-600);
  }
  
  .bejamas-bg-purple-100 {
    background-color: rgba(139, 92, 246, 0.1);
    color: var(--bejamas-color-purple-600);
  }
  
  .bejamas-bg-yellow-100 {
    background-color: rgba(245, 158, 11, 0.1);
    color: var(--bejamas-color-yellow-600);
  }
  
  /* Spacing utilities */
  .bejamas-mt-2 { margin-top: var(--bejamas-space-2); }
  .bejamas-mb-12 { margin-bottom: var(--bejamas-space-12); }
  
  .bejamas-w-full { width: 100%; }
  
  .bejamas-text-center { text-align: center; }
  
  .bejamas-bg-gradient {
    background: linear-gradient(135deg, 
      var(--bejamas-color-bg) 0%, 
      var(--bejamas-color-surface) 100%);
  }
</style>