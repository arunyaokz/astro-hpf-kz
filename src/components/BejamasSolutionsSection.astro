---
import { TRANSLATIONS } from '../consts';

const t = TRANSLATIONS.zh;
---

<section class="bejamas-section bejamas-base">
  <div class="bejamas-container">
    <div class="bejamas-section-header bejamas-text-center">
      <h2 class="bejamas-title-2xl bejamas-heading">{t.solutionsTitle}</h2>
      <p class="bejamas-subtitle bejamas-mt-2">针对不同行业的定制化物流解决方案</p>
    </div>
    
    <div class="bejamas-grid bejamas-grid-cols-1 md:bejamas-grid-cols-2 lg:bejamas-grid-cols-3 bejamas-gap-8">
      <div class="bejamas-solution-card">
        <div class="bejamas-solution-icon bejamas-bg-blue-100">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 10V20M8 10L4 9.99998V20L8 20M8 10L16.5 10M16.5 10L12.5 5.99998L16.5 2M16.5 10L20 9.99998V20L16.5 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">{t.manufacturing}</h3>
        <p class="bejamas-text-base bejamas-text-muted">{t.manufacturingDesc}</p>
        <div class="bejamas-solution-features">
          <span class="bejamas-feature-tag">超尺物流</span>
          <span class="bejamas-feature-tag">项目物流</span>
          <span class="bejamas-feature-tag">工地直达</span>
        </div>
      </div>
      
      <div class="bejamas-solution-card">
        <div class="bejamas-solution-icon bejamas-bg-green-100">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 10L12 12M12 12L10 10M12 12L14 14M12 12L10 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">{t.mining}</h3>
        <p class="bejamas-text-base bejamas-text-muted">{t.miningDesc}</p>
        <div class="bejamas-solution-features">
          <span class="bejamas-feature-tag">危特品合规</span>
          <span class="bejamas-feature-tag">多节点安全</span>
          <span class="bejamas-feature-tag">专业运输</span>
        </div>
      </div>
      
      <div class="bejamas-solution-card">
        <div class="bejamas-solution-icon bejamas-bg-yellow-100">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 12H16M8 8H16M8 16H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">{t.automotive}</h3>
        <p class="bejamas-text-base bejamas-text-muted">{t.automotiveDesc}</p>
        <div class="bejamas-solution-features">
          <span class="bejamas-feature-tag">整机运输</span>
          <span class="bejamas-feature-tag">CKD/SKD</span>
          <span class="bejamas-feature-tag">差异化方案</span>
        </div>
      </div>
      
      <div class="bejamas-solution-card">
        <div class="bejamas-solution-icon bejamas-bg-purple-100">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M16 8L16 16M12 11V16M8 14V16M6 20H18C19.1046 20 20 19.1046 20 18V6C20 4.89543 19.1046 4 18 4H6C4.89543 4 4 4.89543 4 6V18C4 19.1046 4.89543 20 6 20Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">{t.ecommerce}</h3>
        <p class="bejamas-text-base bejamas-text-muted">{t.ecommerceDesc}</p>
        <div class="bejamas-solution-features">
          <span class="bejamas-feature-tag">中高价值SKU</span>
          <span class="bejamas-feature-tag">时效成本平衡</span>
          <span class="bejamas-feature-tag">跨境电商</span>
        </div>
      </div>
      
      <div class="bejamas-solution-card">
        <div class="bejamas-solution-icon bejamas-bg-red-100">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 9H21V21C21 21.2652 20.8946 21.5196 20.7071 21.7071C20.5196 21.8946 20.2652 22 20 22H4C3.73478 22 3.48043 21.8946 3.29289 21.7071C3.10536 21.5196 3 21.2652 3 21V9Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M9 9V3H15V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">{t.retail}</h3>
        <p class="bejamas-text-base bejamas-text-muted">{t.retailDesc}</p>
        <div class="bejamas-solution-features">
          <span class="bejamas-feature-tag">高频补货</span>
          <span class="bejamas-feature-tag">温控协同</span>
          <span class="bejamas-feature-tag">库存健康</span>
        </div>
      </div>
      
      <div class="bejamas-solution-card bejamas-solution-cta">
        <div class="bejamas-solution-icon bejamas-bg-gray-100">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 16V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M12 8H12.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">定制解决方案</h3>
        <p class="bejamas-text-base bejamas-text-muted">根据您的具体需求，提供完全定制化的物流解决方案</p>
        <a href="#contact" class="bejamas-button bejamas-button-primary bejamas-mt-4">
          咨询定制方案
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .bejamas-solution-card {
    background-color: var(--bejamas-color-surface);
    border: 1px solid var(--bejamas-color-border);
    border-radius: var(--bejamas-radius-xl);
    padding: var(--bejamas-space-8);
    transition: all var(--bejamas-transition-base);
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  
  .bejamas-solution-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--bejamas-shadow-lg);
  }
  
  .bejamas-solution-cta {
    background: linear-gradient(135deg, var(--bejamas-color-bg) 0%, var(--bejamas-color-surface) 100%);
    border: 2px dashed var(--bejamas-color-border);
    align-items: center;
    text-align: center;
  }
  
  .bejamas-solution-icon {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--bejamas-radius-lg);
    color: var(--bejamas-color-accent);
    margin-bottom: var(--bejamas-space-4);
  }
  
  .bejamas-solution-features {
    display: flex;
    flex-wrap: wrap;
    gap: var(--bejamas-space-2);
    margin-top: var(--bejamas-space-4);
  }
  
  .bejamas-feature-tag {
    background-color: var(--bejamas-color-bg-muted);
    color: var(--bejamas-color-text-muted);
    padding: var(--bejamas-space-1) var(--bejamas-space-3);
    border-radius: var(--bejamas-radius-full);
    font-size: var(--bejamas-text-xs);
    font-weight: 500;
  }
  
  /* Color variants */
  .bejamas-bg-blue-100 {
    background-color: rgba(59, 130, 246, 0.1);
    color: var(--bejamas-color-blue-600);
  }
  
  .bejamas-bg-green-100 {
    background-color: rgba(16, 185, 129, 0.1);
    color: var(--bejamas-color-green-600);
  }
  
  .bejamas-bg-yellow-100 {
    background-color: rgba(245, 158, 11, 0.1);
    color: var(--bejamas-color-yellow-600);
  }
  
  .bejamas-bg-purple-100 {
    background-color: rgba(139, 92, 246, 0.1);
    color: var(--bejamas-color-purple-600);
  }
  
  .bejamas-bg-red-100 {
    background-color: rgba(239, 68, 68, 0.1);
    color: var(--bejamas-color-red-600);
  }
  
  .bejamas-bg-gray-100 {
    background-color: rgba(156, 163, 175, 0.1);
    color: var(--bejamas-color-gray-600);
  }
  
  /* Responsive design */
  @media (min-width: 768px) {
    .md\:bejamas-grid-cols-2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .lg\:bejamas-grid-cols-3 {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .bejamas-gap-8 {
    gap: var(--bejamas-space-8);
  }
</style>