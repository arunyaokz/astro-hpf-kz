---
import { PRIVACY_COPY, type Lang } from "../site-v2";
interface Props { lang: Lang; }
const { lang } = Astro.props;
const page = PRIVACY_COPY[lang];
---

<article class="legal-page shell">
  <header>
    <p class="eyebrow">{page.eyebrow}</p>
    <h1 class="display">{page.title}</h1>
    <p class="lead">{page.lead}</p>
  </header>
  <div class="legal-list">
    {page.sections.map((section, index) => (
      <section><span>{String(index + 1).padStart(2, "0")}</span><h2>{section.title}</h2><p>{section.text}</p></section>
    ))}
  </div>
</article>

<style>
  .legal-page { display:grid; grid-template-columns:minmax(17rem,.5fr) minmax(0,1.5fr); gap:clamp(3rem,8vw,8rem); padding-block:clamp(6rem,10vw,9rem); background:var(--paper); }
  .legal-page header { display:grid; align-content:start; gap:1.25rem; }
  .legal-page .display { max-width: 10ch; }
  .legal-list { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:.8rem; }
  .legal-list section { display:grid; grid-template-columns:auto 1fr; gap:.75rem 1rem; min-height:14rem; align-content:start; padding:1.5rem; border-radius:1.4rem; background:#fff; box-shadow:0 18px 55px rgba(37,23,91,.06); }
  .legal-list section:first-child { background:linear-gradient(145deg,#38268d,#17112f); color:#fff; }
  .legal-list span { color: var(--cobalt-700); font-family: var(--font-num); font-size: .75rem; }
  .legal-list h2 { color:inherit; font-size:1.2rem; }
  .legal-list p { grid-column:2; color:var(--muted); }
  .legal-list section:first-child p { color:rgba(255,255,255,.64); }
  @media (max-width: 52rem) { .legal-page { grid-template-columns: 1fr; } }
  @media (max-width:38rem) { .legal-list { grid-template-columns:1fr; } .legal-list section { grid-template-columns:2rem 1fr; } .legal-list p { grid-column:2; } }
</style>
