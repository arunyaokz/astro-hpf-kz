---
import { TRANSLATIONS } from '../consts';

const t = TRANSLATIONS.zh;
---

<section class="bejamas-section bejamas-base">
  <!-- 动态渐变背景 -->
  <div class="hero-background">
    <div class="gradient-overlay gradient-1"></div>
    <div class="gradient-overlay gradient-2"></div>
    <div class="gradient-overlay gradient-3"></div>
    <div class="gradient-overlay gradient-4"></div>
    <div class="gradient-overlay gradient-5"></div>
    <div class="gradient-overlay gradient-6"></div>
  </div>
  
  <div class="hero-container">
    <!-- Hero content -->
    <div class="hero-grid">
      <div class="hero-content">
        <div class="hero-tagline bejamas-mb-4">
          和光同尘 · 共创未来
        </div>
        
        <h1 class="bejamas-title-xl bejamas-heading">
          库雷克绿通
          <span class="subtitle">跨里海中间走廊</span>
        </h1>
        
        <p class="bejamas-subtitle bejamas-mb-8">
          端到端确定性物流解决方案，连接中国与欧洲的全新通道，提供高效、可靠的跨境物流服务
        </p>
        
        <div class="cta-buttons bejamas-mb-12">
          <a href="#contact" class="bejamas-button bejamas-button-primary bejamas-mr-4">
            开启绿通服务
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="ml-2">
              <path d="M8 2L14 8L8 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M2 8H14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </a>
          
          <a href="#demo" class="bejamas-button bejamas-button-secondary">
            预约演示
          </a>
        </div>
        
        <!-- Features grid -->
        <div class="features-grid">
          <div class="feature-card bejamas-fade-in" style="animation-delay: 0.1s;">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L2 7V10C2 16 12 22 12 22C12 22 22 16 22 10V7L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M12 8V12L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="feature-content">
              <h3 class="feature-title">优先通行</h3>
              <p class="feature-description">港口协同排期，舱位协调保障</p>
            </div>
          </div>
          
          <div class="feature-card bejamas-fade-in" style="animation-delay: 0.2s;">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-width="1.5"/>
                <path d="M12 6V12L16 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="feature-content">
              <h3 class="feature-title">全链透明</h3>
              <p class="feature-description">实时追踪，可视化物流链路</p>
            </div>
          </div>
          
          <div class="feature-card bejamas-fade-in" style="animation-delay: 0.3s;">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M16 8C17.6569 8 19 6.65685 19 5C19 3.34315 17.6569 2 16 2C14.3431 2 13 3.34315 13 5C13 6.65685 14.3431 8 16 8Z" stroke="currentColor" stroke-width="1.5"/>
                <path d="M8 16C9.65685 16 11 14.6569 11 13C11 11.3431 9.65685 10 8 10C6.34315 10 5 11.3431 5 13C5 14.6569 6.34315 16 8 16Z" stroke="currentColor" stroke-width="1.5"/>
                <path d="M16 22C17.6569 22 19 20.6569 19 19C19 17.3431 17.6569 16 16 16C14.3431 16 13 17.3431 13 19C13 20.6569 14.3431 22 16 22Z" stroke="currentColor" stroke-width="1.5"/>
                <path d="M7 14L15 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="feature-content">
              <h3 class="feature-title">智能风控</h3>
              <p class="feature-description">AI辅助风险预测与异常处置</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Hero visual -->
      <div class="hero-visual bejamas-fade-in">
        <div class="visual-container">
          <div class="map-visual">
            <div class="route-point almaty"><span>阿拉木图</span></div>
            <div class="route-point kurek"><span>库雷克港</span></div>
            <div class="route-point baku"><span>巴库</span></div>
            <div class="route-point istanbul"><span>伊斯坦布尔</span></div>
            <div class="route-line"></div>
            <div class="route-indicator"></div>
          </div>
          <div class="stats-badge">
            <div class="stat-item">
              <span class="stat-number">12天</span>
              <span class="stat-label">平均时效</span>
            </div>
            <div class="stat-item">
              <span class="stat-number">98.5%</span>
              <span class="stat-label">准点率</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* 动态渐变背景样式 */
  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }
  
  .gradient-overlay {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.7;
    mix-blend-mode: overlay;
  }
  
  .gradient-1 {
    width: 400px;
    height: 400px;
    background: linear-gradient(45deg, #6366f1, #8b5cf6);
    top: 10%;
    left: 10%;
    animation: floatGradient 15s ease-in-out infinite;
  }
  
  .gradient-2 {
    width: 300px;
    height: 300px;
    background: linear-gradient(135deg, #10b981, #059669);
    top: 60%;
    right: 15%;
    animation: floatGradient 20s ease-in-out infinite reverse;
  }
  
  .gradient-3 {
    width: 350px;
    height: 350px;
    background: linear-gradient(225deg, #f59e0b, #d97706);
    bottom: 20%;
    left: 20%;
    animation: floatGradient 18s ease-in-out infinite;
  }
  
  .gradient-4 {
    width: 250px;
    height: 250px;
    background: linear-gradient(315deg, #ec4899, #db2777);
    top: 30%;
    right: 30%;
    animation: floatGradient 22s ease-in-out infinite reverse;
  }
  
  .gradient-5 {
    width: 320px;
    height: 320px;
    background: linear-gradient(90deg, #3b82f6, #2563eb);
    bottom: 40%;
    right: 10%;
    animation: floatGradient 16s ease-in-out infinite;
  }
  
  .gradient-6 {
    width: 280px;
    height: 280px;
    background: linear-gradient(270deg, #8b5cf6, #7c3aed);
    top: 20%;
    left: 40%;
    animation: floatGradient 25s ease-in-out infinite reverse;
  }
  
  @keyframes floatGradient {
    0%, 100% {
      transform: translate(0, 0) rotate(0deg);
    }
    25% {
      transform: translate(30px, -20px) rotate(90deg);
    }
    50% {
      transform: translate(-20px, 30px) rotate(180deg);
    }
    75% {
      transform: translate(20px, 20px) rotate(270deg);
    }
  }
  
  .hero-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 var(--bejamas-space-6);
    position: relative;
    z-index: 1;
  }
  
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--bejamas-space-12);
    align-items: center;
    min-height: calc(100vh - 80px);
    padding: var(--bejamas-space-16) 0;
  }
  
  .hero-content {
    max-width: 580px;
  }
  
  .hero-tagline {
    font-size: var(--bejamas-text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--bejamas-color-accent);
  }
  
  .subtitle {
    display: block;
    font-size: var(--bejamas-text-2xl);
    font-weight: 400;
    color: var(--bejamas-color-text-secondary);
    margin-top: var(--bejamas-space-3);
  }
  
  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
  }
  
  .bejamas-mr-4 {
    margin-right: var(--bejamas-space-4);
  }
  
  .features-grid {
    display: grid;
    gap: var(--bejamas-space-4);
  }
  
  .feature-card {
    display: flex;
    align-items: flex-start;
    gap: var(--bejamas-space-3);
    padding: var(--bejamas-space-4);
    background-color: var(--bejamas-color-surface);
    border-radius: var(--bejamas-radius-lg);
    border: 1px solid var(--bejamas-color-border);
    transition: all var(--bejamas-transition-base);
  }
  
  .feature-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--bejamas-shadow-md);
  }
  
  .feature-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(99, 102, 241, 0.1);
    border-radius: var(--bejamas-radius-md);
    color: var(--bejamas-color-accent);
  }
  
  .feature-content {
    flex: 1;
  }
  
  .feature-title {
    font-size: var(--bejamas-text-lg);
    font-weight: 600;
    margin-bottom: var(--bejamas-space-1);
    color: var(--bejamas-color-text);
  }
  
  .feature-description {
    font-size: var(--bejamas-text-sm);
    color: var(--bejamas-color-text-secondary);
    line-height: 1.5;
  }
  
  .hero-visual {
    position: relative;
  }
  
  .visual-container {
    position: relative;
    background-color: var(--bejamas-color-surface);
    border-radius: var(--bejamas-radius-xl);
    padding: var(--bejamas-space-8);
    border: 1px solid var(--bejamas-color-border);
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  
  .map-visual {
    position: relative;
    width: 100%;
    max-width: 400px;
    height: 300px;
  }
  
  .route-point {
    position: absolute;
    width: 12px;
    height: 12px;
    background-color: var(--bejamas-color-accent);
    border-radius: 50%;
    transition: all var(--bejamas-transition-base);
    cursor: pointer;
  }
  
  .route-point::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 24px;
    height: 24px;
    background-color: rgba(99, 102, 241, 0.5);
    border-radius: 50%;
    opacity: 0.5;
    animation: pulse 2s infinite;
  }
  
  .route-point span {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-size: var(--bejamas-text-xs);
    white-space: nowrap;
    color: var(--bejamas-color-text-secondary);
    margin-left: 8px;
  }
  
  .route-point.almaty {
    top: 20%;
    left: 10%;
  }
  
  .route-point.kurek {
    top: 40%;
    left: 35%;
  }
  
  .route-point.baku {
    top: 60%;
    left: 60%;
  }
  
  .route-point.istanbul {
    top: 40%;
    left: 90%;
  }
  
  .route-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, 
      var(--bejamas-color-accent) 0%, 
      rgba(99, 102, 241, 0.5) 50%, 
      var(--bejamas-color-accent) 100%);
    mask-image: url("data:image/svg+xml,%3Csvg width='400' height='300' viewBox='0 0 400 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M40 60 Q 140 120, 250 180 T 360 120' fill='none' stroke='black' stroke-width='3'/%3E%3C/svg%3E");
    mask-size: contain;
    mask-repeat: no-repeat;
    mask-position: center;
    -webkit-mask-image: url("data:image/svg+xml,%3Csvg width='400' height='300' viewBox='0 0 400 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M40 60 Q 140 120, 250 180 T 360 120' fill='none' stroke='black' stroke-width='3'/%3E%3C/svg%3E");
    -webkit-mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
  }
  
  .route-indicator {
    position: absolute;
    width: 16px;
    height: 16px;
    background-color: white;
    border: 2px solid var(--bejamas-color-accent);
    border-radius: 50%;
    top: 60px;
    left: 40px;
    animation: moveIndicator 10s infinite ease-in-out;
    box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.5);
  }
  
  .stats-badge {
    position: absolute;
    bottom: var(--bejamas-space-4);
    right: var(--bejamas-space-4);
    background-color: var(--bejamas-color-bg);
    border: 1px solid var(--bejamas-color-border);
    border-radius: var(--bejamas-radius-lg);
    padding: var(--bejamas-space-3);
    display: flex;
    gap: var(--bejamas-space-4);
    box-shadow: var(--bejamas-shadow-md);
  }
  
  .stat-item {
    text-align: center;
  }
  
  .stat-number {
    display: block;
    font-size: var(--bejamas-text-lg);
    font-weight: 700;
    color: var(--bejamas-color-accent);
  }
  
  .stat-label {
    display: block;
    font-size: var(--bejamas-text-xs);
    color: var(--bejamas-color-text-secondary);
    margin-top: 2px;
  }
  
  /* Animations */
  @keyframes pulse {
    0% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.5;
    }
    50% {
      transform: translate(-50%, -50%) scale(1.5);
      opacity: 0.2;
    }
    100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.5;
    }
  }
  
  @keyframes moveIndicator {
    0% {
      top: 60px;
      left: 40px;
    }
    25% {
      top: 120px;
      left: 140px;
    }
    50% {
      top: 180px;
      left: 250px;
    }
    75% {
      top: 160px;
      left: 280px;
    }
    100% {
      top: 120px;
      left: 360px;
    }
  }
  
  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--bejamas-space-8);
    }
    
    .hero-content {
      max-width: 100%;
      text-align: center;
    }
    
    .cta-buttons {
      justify-content: center;
    }
    
    .features-grid {
      justify-content: center;
    }
    
    .feature-card {
      max-width: 400px;
      margin: 0 auto;
    }
  }
  
  @media (max-width: 640px) {
    .hero-grid {
      padding: var(--bejamas-space-8) 0;
    }
    
    .cta-buttons {
      flex-direction: column;
      align-items: center;
      gap: var(--bejamas-space-3);
    }
    
    .bejamas-mr-4 {
      margin-right: 0;
    }
    
    .visual-container {
      padding: var(--bejamas-space-4);
      min-height: 300px;
    }
    
    .stats-badge {
      bottom: var(--bejamas-space-3);
      right: var(--bejamas-space-3);
      padding: var(--bejamas-space-2);
      gap: var(--bejamas-space-3);
    }
  }
</style>