---
import { COMPANY_NAME, TRANSLATIONS, KPI_DATA } from '../consts';
---

<section class="clean-hero">
  <div class="hero-container">
    
    <!-- 主要内容区域 -->
    <div class="hero-content">
      
      <!-- 品牌标识 -->
      <div class="brand-badge animate-fade-in-up" style="animation-delay: 0.2s;">
        <div class="badge-content">
          <span class="badge-icon">🚀</span>
          <span class="badge-text">{COMPANY_NAME}</span>
        </div>
      </div>
      
      <!-- 主标题 -->
      <!-- 主标题 -->
      <h1 class="hero-title animate-fade-in-up" style="animation-delay: 0.4s;">
        <span class="title-line">让确定性成为</span>
        <span class="title-line gradient-text">跨境物流的默认标准</span>
      </h1>
      
      <!-- 副标题 -->
      <p class="hero-subtitle animate-fade-in-up" style="animation-delay: 0.6s;">
        从不可预测到确定可控
      </p>
      
      <!-- 描述 -->
      <p class="hero-description animate-fade-in-up" style="animation-delay: 0.8s;">
        通过数据驱动的智能决策系统，将跨境物流的不确定性转化为可预期的商业价值，让每一次交付都成为长期合作的信任基石
      </p>
      
      <!-- 行动按钮 -->
      <div class="hero-actions animate-fade-in-up" style="animation-delay: 1s;">
        <button class="btn btn-primary btn-large">
          <span class="btn-text">获取绿通名额</span>
          <span class="btn-icon">→</span>
        </button>
        <button class="btn btn-secondary btn-large">
          <span class="btn-text">预约演示</span>
          <span class="btn-icon">▶</span>
        </button>
      </div>
      
      <!-- 信任标识 -->
      <div class="trust-indicators animate-fade-in-up" style="animation-delay: 1.2s;">
        <div class="trust-item">
          <span class="trust-icon">✓</span>
          <span class="trust-text">ISO认证</span>
        </div>
        <div class="trust-item">
          <span class="trust-icon">✓</span>
          <span class="trust-text">全球网络</span>
        </div>
        <div class="trust-item">
          <span class="trust-icon">✓</span>
          <span class="trust-text">24/7支持</span>
        </div>
      </div>
    </div>
    
    <!-- 运营确定性指标 -->
    <div class="hero-stats animate-fade-in-up" style="animation-delay: 1.4s;">
      <div class="stats-grid">
        <div class="stat-item" data-stat="ontime">
          <div class="stat-value">
            <span class="animated-number" data-target="98.5">0</span>
            <span class="stat-unit">%</span>
          </div>
          <div class="stat-label">准时交付保障</div>
          <div class="stat-sublabel">行业领先水准</div>
          <div class="stat-progress">
            <div class="progress-bar" style="width: 98.5%"></div>
          </div>
        </div>
        
        <div class="stat-item" data-stat="intact">
          <div class="stat-value">
            <span class="animated-number" data-target="99.2">0</span>
            <span class="stat-unit">%</span>
          </div>
          <div class="stat-label">货物完损保护</div>
          <div class="stat-sublabel">全程可视化监控</div>
          <div class="stat-progress">
            <div class="progress-bar" style="width: 99.2%"></div>
          </div>
        </div>
        
        <div class="stat-item" data-stat="response">
          <div class="stat-value">
            <span class="stat-prefix">&lt;</span>
            <span class="animated-number" data-target="2">0</span>
            <span class="stat-unit">H</span>
          </div>
          <div class="stat-label">异常响应速度</div>
          <div class="stat-sublabel">T+0预警机制</div>
          <div class="stat-progress">
            <div class="progress-bar" style="width: 85%"></div>
          </div>
        </div>
        
        <div class="stat-item" data-stat="satisfaction">
          <div class="stat-value">
            <span class="animated-number" data-target="95">0</span>
            <span class="stat-unit">%+</span>
          </div>
          <div class="stat-label">客户信任度</div>
          <div class="stat-sublabel">长期合作伙伴关系</div>
          <div class="stat-progress">
            <div class="progress-bar" style="width: 95%"></div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- 滚动指示器 -->
    <div class="scroll-indicator animate-fade-in" style="animation-delay: 2s;">
      <div class="scroll-text">探索更多</div>
      <div class="scroll-arrow">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M12 5V19M12 19L19 12M12 19L5 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
    
  </div>
</section>

<style>
  .clean-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    background: var(--bg-primary);
    padding: var(--space-24) 0;
  }
  
  .hero-container {
    max-width: 1200px;
    width: 100%;
    padding: 0 var(--space-6);
    text-align: center;
    position: relative;
    z-index: 10;
  }
  
  /* 品牌标识 */
  .brand-badge {
    margin-bottom: var(--space-8);
  }
  
  .badge-content {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    background: transparent;
    color: var(--color-yin);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 300;
    border: 1px solid rgba(26, 26, 26, 0.1);
  }
  
  .badge-icon {
    font-size: var(--text-lg);
  }
  
  /* 主标题 */
  .hero-title {
    margin-bottom: var(--space-8);
    line-height: 1.1;
  }
  
  .title-line {
    display: block;
    font-size: clamp(36px, 6vw, var(--text-6xl));
    font-weight: 200;
    color: var(--color-yin);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-2);
    line-height: 1.1;
  }
  
  .title-line.gradient-text {
    background: linear-gradient(135deg, #ff0000 0%, #ff4757 50%, #ff6b7a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 600;
    position: relative;
  }
  
  .title-line.gradient-text::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, transparent, #ff0000, transparent);
    transform: scaleX(0);
    transform-origin: left;
    animation: underlineExpand 2s ease-out forwards;
    animation-delay: 1.5s;
  }
  
  @keyframes underlineExpand {
    to {
      transform: scaleX(1);
    }
  }
  
  /* 副标题 - 精密工程质感 */
  .hero-subtitle {
    font-size: clamp(18px, 3vw, var(--text-xl));
    font-weight: 400;
    color: var(--color-metal);
    margin-bottom: var(--space-4);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-family: 'JetBrains Mono', monospace;
    opacity: 0.8;
    position: relative;
  }
  
  .hero-subtitle::before {
    content: '';
    position: absolute;
    top: 50%;
    left: -40px;
    width: 30px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-metal));
    transform: translateY(-50%);
  }
  
  .hero-subtitle::after {
    content: '';
    position: absolute;
    top: 50%;
    right: -40px;
    width: 30px;
    height: 1px;
    background: linear-gradient(90deg, var(--color-metal), transparent);
    transform: translateY(-50%);
  }
  
  /* 描述 - 精密工程叙述 */
  .hero-description {
    font-size: clamp(16px, 2vw, var(--text-lg));
    color: var(--color-neutral-600);
    max-width: 700px;
    margin: 0 auto var(--space-8);
    line-height: 1.8;
    font-weight: 300;
    position: relative;
    padding: var(--space-4) var(--space-8);
    border-left: 2px solid rgba(255, 0, 0, 0.2);
    background: linear-gradient(135deg, rgba(255, 0, 0, 0.02), transparent);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }
  
  .hero-description::before {
    content: '';
    position: absolute;
    top: 0;
    left: -2px;
    width: 2px;
    height: 0;
    background: linear-gradient(180deg, #ff0000, #ff6b7a);
    animation: descriptionLine 1.5s ease-out forwards;
    animation-delay: 1.8s;
  }
  
  @keyframes descriptionLine {
    to {
      height: 100%;
    }
  }
  
  /* 行动按钮 */
  .hero-actions {
    display: flex;
    gap: var(--space-6);
    justify-content: center;
    margin-bottom: var(--space-16);
    flex-wrap: wrap;
  }
  
  .btn {
    position: relative;
    overflow: hidden;
    min-width: 180px;
  }
  
  .btn-primary {
    background: #ff0000;
    color: white;
    border: none;
    box-shadow: 0 4px 12px rgba(255, 0, 0, 0.3);
  }
  
  .btn-primary:hover {
    background: #e60000;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255, 0, 0, 0.4);
  }
  
  .btn-secondary {
    background: transparent;
    color: #ff0000;
    border: 1px solid #ff0000;
  }
  
  .btn-secondary:hover {
    background: #ff0000;
    color: white;
    transform: translateY(-2px);
  }
  
  .btn-text {
    font-weight: 300;
    font-size: var(--text-base);
  }
  
  .btn-icon {
    font-size: var(--text-sm);
    transition: transform 0.3s ease;
  }
  
  .btn:hover .btn-icon {
    transform: translateX(4px);
  }
  
  /* 信任标识 */
  .trust-indicators {
    display: flex;
    gap: var(--space-8);
    justify-content: center;
    margin-bottom: var(--space-16);
    flex-wrap: wrap;
  }
  
  .trust-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-metal);
    font-size: var(--text-sm);
    font-weight: 300;
    padding: var(--space-2) var(--space-4);
    background: transparent;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(26, 26, 26, 0.1);
  }
  
  .trust-icon {
    color: var(--color-success);
    font-weight: bold;
  }
  
  /* 数据统计 */
  .hero-stats {
    margin-bottom: var(--space-16);
  }
  
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    max-width: 400px;
    margin: 0 auto;
  }
  
  /* 统计项目 - 精密数据仪表 */
  .stat-item {
    text-align: center;
    padding: var(--space-8);
    border-radius: var(--radius-xl);
    background: var(--bg-primary);
    border: 1px solid var(--color-neutral-200);
    transition: all var(--duration-medium) var(--ease-out);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(10px);
  }

  .stat-item::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(255, 0, 0, 0.03), transparent);
    opacity: 0;
    transition: opacity var(--duration-medium) var(--ease-out);
  }

  .stat-item:hover::before {
    opacity: 1;
  }

  .stat-item:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(255, 0, 0, 0.1);
  .stat-number {
    font-size: clamp(32px, 4vw, var(--text-4xl));
    font-weight: 700;
    color: var(--color-yin);
    margin-bottom: var(--space-2);
    font-family: 'JetBrains Mono', monospace;
    position: relative;
    background: linear-gradient(135deg, var(--color-yin), var(--color-neutral-600));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .stat-number::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 2px;
    background: linear-gradient(90deg, transparent, #ff0000, transparent);
    opacity: 0.6;
  }   display: flex;
    align-items: baseline;
    justify-content: center;
    gap: var(--space-1);
  }
  
  .stat-unit,
  .stat-prefix {
    font-size: 0.6em;
    color: #ff0000;
    font-weight: 400;
  }
  
  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-yin);
    font-weight: 300;
    margin-bottom: var(--space-1);
  }
  
  .stat-sublabel {
    font-size: var(--text-xs);
    color: var(--color-metal);
    font-weight: 300;
    margin-bottom: var(--space-4);
  }
  
  .stat-progress {
    width: 100%;
    height: 4px;
    background: var(--bg-tertiary);
    border-radius: 2px;
    overflow: hidden;
  }
  
  .progress-bar {
    height: 100%;
    background: #ff0000;
    border-radius: 2px;
    animation: progressFill 2s ease-out forwards;
  }
  
  /* 滚动指示器 */
  .scroll-indicator {
     position: absolute;
     bottom: var(--space-8);
     left: 50%;
     transform: translateX(-50%);
     text-align: center;
     color: var(--color-metal);
   }
  
  .scroll-text {
    font-size: var(--text-sm);
    font-weight: 300;
    margin-bottom: var(--space-3);
    opacity: 0.6;
  }
  
  .scroll-arrow {
    animation: bounce 2s infinite;
  }
  
  /* 动画 */
  @keyframes progressFill {
    from {
      width: 0%;
    }
    to {
      width: var(--progress-width);
    }
  }
  
  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% {
      transform: translateY(0);
    }
    40% {
      transform: translateY(-8px);
    }
    60% {
      transform: translateY(-4px);
    }
  }
  
  /* 响应式设计 */
  @media (max-width: 768px) {
    .clean-hero {
      min-height: auto;
      padding: var(--space-16) 0;
    }
    
    .hero-container {
      padding: 0 var(--space-4);
    }
    
    .hero-actions {
      flex-direction: column;
      align-items: center;
      gap: var(--space-4);
      margin-bottom: var(--space-12);
    }
    
    .btn {
      width: 100%;
      max-width: 280px;
    }
    
    .trust-indicators {
      gap: var(--space-4);
      margin-bottom: var(--space-12);
    }
    
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }
    
    .stat-item {
      padding: var(--space-6);
    }
  }
  
  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    
    .trust-indicators {
      flex-direction: column;
      align-items: center;
      gap: var(--space-3);
    }
    
    .title-line {
      font-size: clamp(36px, 12vw, var(--text-6xl));
    }
  }
  
  /* 减少动画偏好 */
  @media (prefers-reduced-motion: reduce) {
    .clean-hero * {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script>
  class CleanHero {
    constructor() {
      this.animatedNumbers = document.querySelectorAll('.animated-number');
      this.progressBars = document.querySelectorAll('.progress-bar');
      this.init();
    }
    
    init() {
      this.animateNumbers();
      this.setupIntersectionObserver();
      this.setupScrollIndicator();
    }
    
    animateNumbers() {
      this.animatedNumbers.forEach((element, index) => {
        const target = parseFloat(element.getAttribute('data-target'));
        const duration = 2000;
        const startDelay = 1500 + (index * 200);
        
        setTimeout(() => {
          this.animateValue(element, 0, target, duration);
        }, startDelay);
      });
    }
    
    animateValue(element, start, end, duration) {
      const startTime = performance.now();
      const isDecimal = end % 1 !== 0;
      
      const updateValue = (currentTime) => {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        
        const easeProgress = 1 - Math.pow(1 - progress, 3);
        const current = start + (end - start) * easeProgress;
        
        if (isDecimal) {
          element.textContent = current.toFixed(1);
        } else {
          element.textContent = Math.round(current);
        }
        
        if (progress < 1) {
          requestAnimationFrame(updateValue);
        } else {
          element.textContent = isDecimal ? end.toFixed(1) : end;
        }
      };
      
      requestAnimationFrame(updateValue);
    }
    
    setupIntersectionObserver() {
      const options = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
      };
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
          }
        });
      }, options);
      
      document.querySelectorAll('.stat-item').forEach(item => {
        observer.observe(item);
      });
    }
    
    setupScrollIndicator() {
      const scrollIndicator = document.querySelector('.scroll-indicator');
      if (scrollIndicator) {
        scrollIndicator.addEventListener('click', () => {
          const nextSection = document.querySelector('.clean-hero').nextElementSibling;
          if (nextSection) {
            nextSection.scrollIntoView({ 
              behavior: 'smooth',
              block: 'start' 
            });
          }
        });
      }
    }
  }
  
  // 初始化
  document.addEventListener('DOMContentLoaded', () => {
    new CleanHero();
  });
</script>