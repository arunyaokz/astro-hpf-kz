---
import { getCollection } from "astro:content";
import { COMPANY_STORY, PAGE_COPY, pagePath, type Lang } from "../site-v2";
import RouteMap from "./RouteMap.astro";
import CardVisual from "./CardVisual.astro";
import ContactPanel from "./ContactPanel.astro";

interface Props { lang: Lang; pageKey: "services" | "routes" | "about"; }
const { lang, pageKey } = Astro.props;
const scopeVisuals: Record<Props["pageKey"], string[]> = {
  services: ["customs", "transport", "warehouse", "delivery"],
  routes: ["cargo-route", "customs", "transport", "delivery"],
  about: ["responsibility", "docs-first", "declaration", "memory"],
};
const processVisuals: Record<Props["pageKey"], string[]> = {
  services: ["documents", "verification", "inspection", "release"],
  routes: ["documents", "responsibility", "cargo-route", "verification"],
  about: ["documents", "responsibility", "memory", "verification"],
};
const boundaryVisuals: Record<Props["pageKey"], string[]> = {
  services: ["commitment", "exclusion"],
  routes: ["route-direction", "route-boundary"],
  about: ["responsibility", "exclusion"],
};
const entityVisuals = ["company", "bin", "calendar", "founder", "warehouse"];
const page = PAGE_COPY[pageKey][lang];
const companyStory = COMPANY_STORY[lang];
const heroImage = {
  services: { src: "/images/corporate/hero-services-customs.webp", size: { width: 1122, height: 1402 }, alt: { zh: "仓内验货与清关前置作业", en: "Warehouse inspection and customs-ready handling", ru: "Складская проверка и подготовка к таможне" } },
  routes: { src: "/images/corporate/hero-routes-tir.webp", size: { width: 1122, height: 1402 }, alt: { zh: "白色 HPF.kz TIR 公路运输车队穿越哈萨克草原", en: "White HPF.kz TIR road freight convoy across the Kazakh steppe", ru: "Белая автоколонна HPF.kz TIR в казахской степи" } },
  about: { src: "/images/corporate/hero-about-team.webp", size: { width: 1003, height: 1568 }, alt: { zh: "阿拉木图团队讨论跨境路线", en: "Almaty team reviewing a cross-border route", ru: "Команда в Алматы обсуждает трансграничный маршрут" } },
}[pageKey];
const labels = {
  en: { do: "We commit to", dont: "We do not claim", image: "Operational scene visualization", scope: "Scope / operating detail", process: "Process", boundary: "Promise boundary" },
  zh: { do: "我们承诺的", dont: "我们不承诺的", image: "运营场景示意图", scope: "范围 / 运营细节", process: "责任次序", boundary: "承诺边界" },
  ru: { do: "Что мы обязуемся делать", dont: "Чего мы не заявляем", image: "Операционная сценическая визуализация", scope: "Объём / детали работы", process: "Порядок работы", boundary: "Граница обещания" },
}[lang];
const facts = pageKey === "about" ? await getCollection("facts") : [];
const factMap = new Map(facts.map((fact) => [fact.id, fact.data]));
const entityFactIds = ["legal_name", "bin", "registration_year", "founder", "office_address"];
const entityLabels = {
  en: { eyebrow: "Registered entity", title: "Legal identity, documented.", note: "Legal identity: Kazakhstan eGov certificate issued 27 May 2025. Office location: company-provided; building and street verified on 2GIS." },
  zh: { eyebrow: "法人登记", title: "法人身份，有文件可查。", note: "法人身份来源：2025 年 5 月 27 日签发的哈萨克斯坦 eGov 证明。办公地点由公司提供，楼宇及街道经 2GIS 核对。" },
  ru: { eyebrow: "Юридическое лицо", title: "Юридические данные подтверждены документом.", note: "Юридические данные: справка eGov от 27 мая 2025 г. Адрес офиса предоставлен компанией; здание и улица проверены по 2ГИС." },
}[lang];
const showEntityFact = (id: string) => {
  const fact = factMap.get(id);
  const pending = lang === "zh" ? "待确认" : lang === "ru" ? "Ожидает подтверждения" : "Pending confirmation";
  return fact?.verified ? fact.localizedValues?.[lang] ?? fact.value : `[${pending}]`;
};
---

<article class="content-page">
  <section class="page-hero shell">
    <div class="page-hero__copy">
      <p class="eyebrow">{page.eyebrow}</p>
      <h1 class="display">{page.title}</h1>
      <p class="lead">{page.lead}</p>
      <div class="hero-actions">
        <a class="button button--primary" href={pagePath(lang, "contact")}>{page.primary}</a>
        <a class="text-link" href={pageKey === "routes" || pageKey === "about" ? pagePath(lang, "services") : pagePath(lang, "routes")}>{page.secondary}<span aria-hidden="true">→</span></a>
      </div>
    </div>
    <figure>
      <img src={heroImage.src} alt={heroImage.alt[lang]} width={heroImage.size.width} height={heroImage.size.height} fetchpriority="high" />
      <figcaption>{labels.image}</figcaption>
    </figure>
  </section>

  {pageKey === "routes" && (
    <section class="route-section">
      <div class="shell"><RouteMap lang={lang} direction={lang === "zh" ? "货物流向：中国 → 欧洲，由右向左" : lang === "ru" ? "Поток груза: Китай → Европа, справа налево" : "Cargo flow: China → Europe, right to left"} /></div>
    </section>
  )}

  {pageKey === "about" && (
    <section class="company-compass">
      <div class="shell">
        <header>
          <p class="eyebrow">{companyStory.compassEyebrow}</p>
          <h2 class="section-title">{companyStory.compassTitle}</h2>
          <p>{companyStory.compassLead}</p>
        </header>
        <div class="compass-pillars">
          {companyStory.pillars.map((pillar) => (
            <article>
              <div><span>{pillar.number}</span><p>{pillar.label}</p></div>
              <h3>{pillar.title}</h3>
              <p>{pillar.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {pageKey === "about" && (
    <section class="entity shell">
      <header><p class="eyebrow">{entityLabels.eyebrow}</p><h2 class="section-title">{entityLabels.title}</h2><small>{entityLabels.note}</small></header>
      <dl>
        {entityFactIds.map((id, index) => {
          const fact = factMap.get(id);
          return <div><CardVisual kind={entityVisuals[index]} /><span>{String(index + 1).padStart(2, "0")}</span><dt>{fact?.labels[lang]}</dt><dd>{fact?.url ? <a href={fact.url} target="_blank" rel="noreferrer">{showEntityFact(id)}</a> : showEntityFact(id)}</dd></div>;
        })}
      </dl>
    </section>
  )}

  <section class="scope shell">
    <header class="scope-intro">
      <p class="eyebrow">{pageKey === "about" ? companyStory.valuesEyebrow : labels.scope}</p>
      <h2 class="section-title">{pageKey === "about" ? companyStory.valuesTitle : page.sectionTitle}</h2>
      <p>{page.sectionLead}</p>
    </header>
    <div class="scope-list">
      {page.sections.map((section, index) => (
        <article>
          <CardVisual kind={scopeVisuals[pageKey][index]} />
          <span>{String(index + 1).padStart(2, "0")}</span>
          <div><p class="item-label">{section.label}</p><h3>{section.title}</h3><p>{section.text}</p></div>
          <ul>{section.points.map((point) => <li>{point}</li>)}</ul>
        </article>
      ))}
    </div>
  </section>

  <section class="sequence">
    <div class="shell sequence-grid">
      <header><p class="eyebrow">{labels.process}</p><h2 class="section-title">{page.processTitle}</h2></header>
      <ol>
        {page.process.map((item, index) => (
          <li><CardVisual kind={processVisuals[pageKey][index]} /><span>{item.step}</span><h3>{item.title}</h3><p>{item.text}</p></li>
        ))}
      </ol>
    </div>
  </section>

  <section class="boundary shell">
    <header><p class="eyebrow">{labels.boundary}</p><h2 class="section-title">{page.boundaryTitle}</h2></header>
    <div class="boundary-grid">
      <div><CardVisual kind={boundaryVisuals[pageKey][0]} /><h3>{labels.do}</h3><ul>{page.boundaryDo.map((item) => <li>{item}</li>)}</ul></div>
      <div><CardVisual kind={boundaryVisuals[pageKey][1]} /><h3>{labels.dont}</h3><ul>{page.boundaryDont.map((item) => <li>{item}</li>)}</ul></div>
    </div>
  </section>

  {pageKey === "about" ? <ContactPanel lang={lang} /> : <section class="page-cta">
    <div class="shell">
      <div><h2>{page.ctaTitle}</h2><p>{page.ctaText}</p></div>
      <a class="button button--inverse" href={pagePath(lang, "contact")}>{page.ctaButton}</a>
    </div>
  </section>}
</article>

<style>
  .content-page { overflow: hidden; background: var(--paper); }
  .page-hero { display: grid; grid-template-columns: minmax(0, 1.08fr) minmax(20rem, .92fr); gap: clamp(3rem, 7vw, 7rem); align-items: center; min-height: 41rem; padding-block: clamp(5rem, 9vw, 8rem); background: var(--ink); box-shadow: 0 0 0 100vmax var(--ink); clip-path: inset(0 -100vmax); }
  .page-hero__copy { display: flex; min-width: 0; flex-direction: column; align-items: flex-start; justify-content: center; gap: 1.25rem; }
  .page-hero .eyebrow { color: var(--electric); }
  .page-hero .display { max-width: 11ch; color: #fff; }
  .page-hero .lead { color: var(--muted-on-dark); }
  .page-hero .text-link { color: var(--electric); }
  .hero-actions { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2); margin-block-start: var(--space-2); }
  .page-hero figure { position: relative; min-height: 32rem; overflow: hidden; border: 1px solid rgba(255,255,255,.1); border-radius: 2rem; background: var(--ink-2); box-shadow: 0 28px 90px rgba(0,0,0,.28); }
  .page-hero figure::after { position: absolute; inset: 0; background: linear-gradient(180deg,rgba(15,8,48,.05),rgba(15,8,48,.62)); content: ""; }
  .page-hero img { width: 100%; height: 100%; object-fit: cover; filter: saturate(.72) contrast(1.04); }
  .content-page:has(.route-section) .page-hero img { object-position: 60% center; }
  .content-page:has(.entity) .page-hero img { object-position: 56% center; }
  .content-page:not(:has(.route-section, .entity)) .page-hero img { object-position: 62% center; }
  .page-hero figcaption { position: absolute; z-index: 1; inset-inline: 0.75rem; inset-block-end: 0.75rem; color: rgba(255,255,255,.8); font-size: 0.6875rem; }
  .route-section { background: var(--ink-2); }
  .route-section > div { padding-block: clamp(4rem,8vw,7rem); }
  .company-compass { background:#fff; }
  .company-compass > div { display:grid; grid-template-columns:minmax(20rem,.72fr) minmax(0,1.28fr); gap:clamp(3rem,7vw,7rem); padding-block:clamp(6rem,10vw,9rem); }
  .company-compass header { display:grid; align-content:start; gap:var(--space-2); }
  .company-compass header .section-title { max-width:11ch; }
  .company-compass header > p:last-child { max-width:55ch; color:var(--muted); }
  .compass-pillars { display:grid; }
  .compass-pillars article { display:grid; grid-template-columns:7rem minmax(0,1fr); gap:.75rem 1.5rem; padding-block:2rem; border-top:1px solid var(--line); }
  .compass-pillars article:last-child { border-bottom:1px solid var(--line); }
  .compass-pillars article > div { grid-row:1 / span 2; }
  .compass-pillars span { color:var(--violet); font-family:var(--font-num); font-size:.72rem; }
  .compass-pillars article > div p { margin-block-start:.45rem; color:var(--muted); font-size:.8rem; }
  .compass-pillars h3 { max-width:22ch; font-size:clamp(1.35rem,2.2vw,2rem); line-height:1.06; }
  .compass-pillars article > p { max-width:58ch; color:var(--muted); }
  .entity { display: grid; grid-template-columns: minmax(34rem,.7fr) minmax(0,1.3fr); gap: clamp(2rem,5vw,5rem); padding-block: clamp(5rem,9vw,8rem); }
  .entity header { display: grid; min-width: 0; align-content: start; gap: var(--space-2); }
  .entity header .section-title { max-width: 9ch; overflow-wrap: normal; font-size: clamp(2.4rem,4.2vw,4.8rem); }
  .entity header small { color: var(--muted); }
  .entity dl { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: .8rem; margin: 0; }
  .entity dl div { position: relative; display: grid; grid-template-columns: auto 1fr; gap: .5rem 1rem; min-height: 10rem; align-content: space-between; padding: 1.35rem; overflow: hidden; isolation: isolate; border-radius: 1.35rem; background: #fff; box-shadow: 0 18px 55px rgba(37,23,91,.06); }
  .entity dl div:last-child { grid-column: 1 / -1; min-height: auto; }
  .entity dl div :global(.card-visual) { position: absolute; z-index: 0; width: 56%; height: 3.6rem; inset: 2.8rem .35rem auto auto; color: #302957; opacity: .34; --visual-accent: #7057ff; --visual-ink: #302957; }
  .entity dl span { position: relative; z-index: 1; color: var(--cobalt-700); font-family: var(--font-num); font-size: .75rem; }
  .entity dt { position: relative; z-index: 1; color: var(--muted); font-size: .8rem; }
  .entity dd { position: relative; z-index: 1; grid-column: 2; margin: 0; color: var(--text); font-size: 1rem; font-weight: 700; overflow-wrap: anywhere; }
  .scope { display: grid; grid-template-columns: minmax(17rem,.52fr) minmax(0,1.48fr); gap: clamp(3rem,7vw,7rem); padding-block: clamp(6rem,10vw,9rem); }
  .scope-intro { display: grid; align-content: start; gap: var(--space-2); }
  .scope-intro > p:last-child { color: var(--mut); }
  .scope-list { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: .8rem; }
  .scope-list article { position: relative; display: grid; grid-template-columns: auto 1fr; gap: 1rem; min-height: 18rem; overflow: hidden; isolation: isolate; align-content: space-between; padding: 1.5rem; border-radius: 1.5rem; background: #fff; }
  .scope-list article:nth-child(1) { background: linear-gradient(145deg,#39288e,#17112f); color: #fff; }
  .scope-list article:nth-child(3) { background: #dfdcff; }
  .scope-list article > span, .sequence li > span { position: relative; z-index: 1; color: var(--cobalt-700); font-family: var(--font-num); font-size: 0.75rem; }
  .scope-list article > div, .scope-list article > ul { position: relative; z-index: 1; }
  .scope-list article :global(.card-visual) { position: absolute; z-index: 0; width: 58%; height: 5.4rem; inset: auto .5rem 1.3rem auto; color: #2d2850; opacity: .4; --visual-accent: #7057ff; --visual-ink: #2d2850; }
  .scope-list article:nth-child(1) :global(.card-visual) { color: #e8e5ff; opacity: .5; --visual-accent: #8d7bff; --visual-ink: #e8e5ff; }
  .scope-list article:nth-child(3) :global(.card-visual) { --visual-accent: #5941e5; }
  .item-label { margin-block-end: 0.5rem; color: var(--cobalt-700); font-family: var(--font-num); font-size: 0.75rem; text-transform: uppercase; }
  .scope-list h3 { font-size: 1.25rem; }
  .scope-list div > p:last-child { margin-block-start: .75rem; color: var(--muted); }
  .scope-list article:nth-child(1) h3 { color:#fff; }
  .scope-list article:nth-child(1) div > p:last-child,.scope-list article:nth-child(1) li { color:rgba(255,255,255,.66); }
  .scope-list ul, .boundary ul { margin: 0; padding-inline-start: 1.125rem; }
  .scope-list li { margin-block-end: 0.375rem; color: var(--tx); font-size: 0.875rem; }
  .sequence { background: var(--ink-2); color: #fff; }
  .sequence-grid { display: grid; grid-template-columns: minmax(34rem,.7fr) minmax(0,1.3fr); gap: clamp(2rem,5vw,5rem); padding-block: clamp(6rem,10vw,9rem); }
  .sequence h2 { color:#fff; }
  .sequence header { display: grid; min-width: 0; align-content: start; gap: var(--space-2); }
  .sequence header .section-title { max-width: 9ch; overflow-wrap: normal; font-size: clamp(2.4rem,3.6vw,4rem); }
  .sequence ol { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:.8rem; margin:0; padding:0; list-style:none; }
  .sequence li { position: relative; display:grid; grid-template-columns:auto 1fr; gap:1rem; min-height:12rem; overflow: hidden; isolation: isolate; align-content:space-between; padding:1.4rem; border:1px solid rgba(255,255,255,.1); border-radius:1.4rem; background:rgba(255,255,255,.045); }
  .sequence li :global(.card-visual) { position: absolute; z-index: 0; width: 58%; height: 4rem; inset: 2.7rem .4rem auto auto; color: #dcd7ff; opacity: .38; --visual-accent: #8d7bff; --visual-ink: #dcd7ff; }
  .sequence h3 { position: relative; z-index: 1; color:#fff; }
  .sequence h3 { font-size: 1rem; }
  .sequence p { position: relative; z-index: 1; grid-column:2; color:var(--muted-on-dark); }
  .boundary { display:grid; grid-template-columns:minmax(17rem,.52fr) minmax(0,1.48fr); gap:clamp(3rem,7vw,7rem); padding-block:clamp(6rem,10vw,9rem); }
  .boundary header { display: grid; min-width: 0; align-content: start; gap: var(--space-2); }
  .boundary-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:.8rem; }
  .boundary-grid > div { position:relative; min-height:18rem; overflow:hidden; isolation:isolate; padding:1.5rem; border-radius:1.4rem; background:#fff; box-shadow:0 18px 55px rgba(37,23,91,.06); }
  .boundary-grid > div + div { background:#e6e3ff; }
  .boundary-grid > div :global(.card-visual) { position:absolute; z-index:0; width:62%; height:7.4rem; inset:auto .5rem .6rem auto; color:#302957; opacity:.4; --visual-accent:#7057ff; --visual-ink:#302957; }
  .boundary-grid > div + div :global(.card-visual) { color:#31295d; opacity:.38; --visual-accent:#5941e5; --visual-ink:#31295d; }
  .boundary-grid h3, .boundary-grid ul { position:relative; z-index:1; }
  .boundary h3 { font-size: 1rem; }
  .boundary ul { margin-block-start: var(--space-2); }
  .boundary li { margin-block-end: 0.75rem; color: var(--mut); }
  .page-cta { position:relative; overflow:hidden; background:var(--ink); color:var(--text-on-dark); }
  .page-cta::after { position:absolute; width:45rem; height:25rem; inset:auto auto -18rem 50%; transform:translateX(-50%); border-radius:50%; background:radial-gradient(circle,rgba(103,67,247,.58),transparent 70%); content:""; }
  .page-cta > div { position:relative; z-index:1; display:grid; grid-template-columns:minmax(0,1fr) auto; gap:var(--space-4); align-items:end; padding-block:clamp(6rem,10vw,9rem); }
  .page-cta h2 { max-width:15ch; color:#fff; font-size:clamp(2.8rem,5vw,5.2rem); letter-spacing:-.055em; }
  .page-cta p { max-width:50ch; margin-block-start:1.25rem; color:var(--muted-on-dark); }
  @media (max-width: 60rem) { .page-hero { grid-template-columns: minmax(0,1.1fr) minmax(18rem,.9fr); } .company-compass > div,.entity, .scope, .sequence-grid, .boundary { grid-template-columns: 1fr; } }
  @media (max-width: 42rem) { .page-hero { grid-template-columns:1fr; min-height:auto; padding-block:4.5rem; } .page-hero figure { min-height:23rem; } .company-compass > div,.entity,.scope,.sequence-grid,.boundary { padding-block:5rem; } .compass-pillars article { grid-template-columns:1fr; } .compass-pillars article > div { grid-row:auto; } .entity dl,.scope-list,.sequence ol,.boundary-grid { grid-template-columns:1fr; } .entity dl div:last-child { grid-column:auto; } .scope-list article { min-height:15rem; } .page-cta > div { grid-template-columns:1fr; align-items:start; } }
</style>
