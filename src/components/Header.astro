---
import { LANGS, UI, pagePath, type CorePage, type Lang } from "../site-v2";

interface Props { lang?: Lang; active?: CorePage; }

const { lang = "en", active = "home" } = Astro.props;
const ui = UI[lang];
const navPages: CorePage[] = ["services", "routes", "about", "contact"];
---

<header class="site-header">
  <nav class="shell nav" aria-label="Primary navigation">
    <a class="wordmark" href={pagePath(lang, "home")} aria-label="HPF.kz home">
      <img src="/brand/hpf-mark.svg" alt="HPF KZ" width="260" height="96" />
    </a>

    <div class="desktop-links">
      {navPages.map((page) => (
        <a href={pagePath(lang, page)} aria-current={active === page ? "page" : undefined}>{ui.nav[page]}</a>
      ))}
    </div>

    <div class="nav-actions">
      <div class="languages" aria-label={ui.language}>
        {LANGS.map((code) => (
          <a class:list={{ active: code === lang }} href={pagePath(code, active)} hreflang={code === "zh" ? "zh-CN" : code}>{code === "zh" ? "中" : code.toUpperCase()}</a>
        ))}
      </div>
      <a class="nav-cta" href={pagePath(lang, "contact")}>{ui.inquiry}</a>
      <button class="menu-button" type="button" data-menu-open aria-controls="site-menu" aria-expanded="false">{ui.menu}</button>
    </div>
  </nav>
</header>

<dialog id="site-menu" class="mobile-menu" data-menu>
  <div class="mobile-head">
    <img src="/brand/hpf-mark.svg" alt="HPF KZ" width="260" height="96" />
    <button type="button" data-menu-close>{ui.close}</button>
  </div>
  <nav aria-label="Mobile navigation">
    {navPages.map((page, index) => (
      <a href={pagePath(lang, page)} data-menu-link aria-current={active === page ? "page" : undefined}>
        <span>{String(index + 1).padStart(2, "0")}</span>
        <strong>{ui.nav[page]}</strong>
      </a>
    ))}
  </nav>
  <div class="mobile-foot">
    <p>{ui.language}</p>
    <div class="mobile-languages">
      {LANGS.map((code) => (
        <a class:list={{ active: code === lang }} href={pagePath(code, active)}>{code === "zh" ? "中文" : code === "ru" ? "Русский" : "English"}</a>
      ))}
    </div>
    <a class="button button--primary" href={pagePath(lang, "contact")} data-menu-link>{ui.inquiry}</a>
  </div>
</dialog>

<script>
  const menu = document.querySelector<HTMLDialogElement>("[data-menu]");
  const opener = document.querySelector<HTMLButtonElement>("[data-menu-open]");
  const closer = document.querySelector<HTMLButtonElement>("[data-menu-close]");
  const closeMenu = () => {
    menu?.close();
    opener?.setAttribute("aria-expanded", "false");
  };

  opener?.addEventListener("click", () => {
    menu?.showModal();
    opener.setAttribute("aria-expanded", "true");
    closer?.focus();
  });
  closer?.addEventListener("click", closeMenu);
  menu?.addEventListener("click", (event) => {
    if (event.target === menu) closeMenu();
  });
  menu?.querySelectorAll("[data-menu-link]").forEach((link) => link.addEventListener("click", closeMenu));
</script>

<style>
  .site-header { position: absolute; z-index: var(--z-header); inset: 0 0 auto; border: 0; background: linear-gradient(180deg,rgba(5,3,18,.68),rgba(5,3,18,.18) 58%,transparent); color: #fff; }
  .nav { display: grid; min-height: var(--header-height); grid-template-columns: 8.25rem minmax(0,1fr) auto; align-items: center; gap: var(--space-3); }
  .wordmark { display: inline-flex; width: 6.9rem; align-items: center; }
  .wordmark img { width: 100%; height: auto; }
  .desktop-links { display: flex; justify-content: center; gap: .25rem; }
  .desktop-links a { position: relative; padding: .75rem 1rem; color: rgba(255,255,255,.62); font-size: .85rem; font-weight: 600; white-space: nowrap; }
  .desktop-links a::after { position: absolute; width: .25rem; height: .25rem; inset: auto auto .18rem 50%; transform: translateX(-50%) scale(0); border-radius: 50%; background: var(--electric); content: ""; transition: transform 180ms var(--ease-out); }
  .desktop-links a[aria-current="page"] { color: #fff; }
  .desktop-links a[aria-current="page"]::after { transform: translateX(-50%) scale(1); }
  .nav-actions,.languages { display: flex; align-items: center; }
  .nav-actions { gap: .7rem; }
  .languages { padding: .18rem; border: 1px solid rgba(255,255,255,.16); border-radius: 999px; background: rgba(5,3,18,.16); }
  .languages a { display: inline-flex; min-width: 2rem; min-height: 2rem; align-items: center; justify-content: center; border-radius: 999px; color: rgba(255,255,255,.48); font-family: var(--font-num); font-size: .63rem; }
  .languages a.active { background: rgba(255,255,255,.12); color: #fff; }
  .nav-cta,.menu-button { display: inline-flex; min-height: 2.7rem; align-items: center; justify-content: center; border-radius: 999px; font-size: .82rem; font-weight: 720; }
  .nav-cta { padding-inline: 1.1rem; background: #fff; color: var(--ink); }
  .menu-button { display: none; padding-inline: 1rem; border: 1px solid rgba(255,255,255,.14); background: rgba(255,255,255,.06); color: #fff; }
  .mobile-menu { width: min(100%,32rem); max-width: none; height: 100%; max-height: none; margin: 0 0 0 auto; padding: 0; border: 0; background: #0e0929; color: #fff; }
  .mobile-menu::backdrop { background: rgba(4,2,15,.72); backdrop-filter: blur(6px); }
  .mobile-menu[open] { display: grid; grid-template-rows: auto 1fr auto; }
  .mobile-head { display: flex; min-height: var(--header-height); align-items: center; justify-content: space-between; padding-inline: var(--space-2); border-bottom: 1px solid rgba(255,255,255,.1); }
  .mobile-head img { width: 6.9rem; height: auto; }
  .mobile-head button { min-height: 2.7rem; padding-inline: 1rem; border: 1px solid rgba(255,255,255,.14); border-radius: 999px; background: rgba(255,255,255,.06); color: #fff; }
  .mobile-menu nav { padding: var(--space-3) var(--space-2); }
  .mobile-menu nav a { display: grid; grid-template-columns: 2.5rem 1fr; gap: var(--space-2); align-items: baseline; padding-block: var(--space-3); border-bottom: 1px solid rgba(255,255,255,.1); }
  .mobile-menu nav span { color: var(--electric); font-family: var(--font-num); font-size: .72rem; }
  .mobile-menu nav strong { color: rgba(255,255,255,.78); font-size: clamp(1.6rem,7vw,2.4rem); letter-spacing: -.04em; }
  .mobile-menu nav a[aria-current="page"] strong { color: #fff; }
  .mobile-foot { display: grid; gap: var(--space-2); padding: var(--space-3) var(--space-2) max(var(--space-3),env(safe-area-inset-bottom)); border-top: 1px solid rgba(255,255,255,.1); }
  .mobile-foot p { color: rgba(255,255,255,.5); font-size: .8rem; }
  .mobile-languages { display: flex; flex-wrap: wrap; gap: .5rem; }
  .mobile-languages a { padding: .6rem .8rem; border: 1px solid rgba(255,255,255,.12); border-radius: 999px; color: rgba(255,255,255,.58); }
  .mobile-languages a.active { background: rgba(255,255,255,.1); color: #fff; }
  @media (hover:hover) and (pointer:fine) { .desktop-links a:hover { color:#fff; } .nav-cta:hover { transform:translateY(-1px); } }
  @media (max-width:67rem) { .desktop-links,.nav-cta { display:none; } .nav { grid-template-columns:1fr auto; } .menu-button { display:inline-flex; } }
  @media (max-width:35rem) { .languages { display:none; } }
</style>
