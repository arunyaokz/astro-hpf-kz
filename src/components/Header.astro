---
import { COMPANY_NAME } from "../consts";
import { NAV_LINKS, SITE_NAV, type NavKey } from "../site-content";

interface Props {
  active?: NavKey;
}

const { active = "home" } = Astro.props;
---

<header class="site-header">
  <nav class="nav-edge page-shell" aria-label="Primary navigation">
    <a class="wordmark" href="/" aria-label={`${COMPANY_NAME} home`}>
      <img src="/brand/hpf-mark-dark.svg" alt="HPF KZ" width="160" height="64" />
    </a>
    <button class="menu-trigger" type="button" data-menu-open aria-controls="site-menu" aria-expanded="false">
      <span data-label-zh="目录" data-label-en="Index" data-label-ru="Меню">目录</span>
      <span aria-hidden="true">↗</span>
    </button>
  </nav>
</header>

<dialog class="site-menu" id="site-menu" data-site-menu>
  <div class="menu-frame page-shell">
    <div class="menu-topline">
      <span class="menu-brand">HPF.KZ / ALMATY</span>
      <button class="menu-close" type="button" data-menu-close aria-label="Close menu">×</button>
    </div>

    <div class="menu-body">
      <p class="menu-intro" data-label-zh="中国 · 哈萨克斯坦 · 欧洲" data-label-en="China · Kazakhstan · Europe" data-label-ru="Китай · Казахстан · Европа">
        中国 · 哈萨克斯坦 · 欧洲
      </p>
      <div class="menu-index">
        {NAV_LINKS.map((item, index) => (
          <a href={item.href} class:list={{ current: item.key === active }} data-menu-link>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong
              data-label-zh={SITE_NAV.zh[item.key]}
              data-label-en={SITE_NAV.en[item.key]}
              data-label-ru={SITE_NAV.ru[item.key]}
            >
              {SITE_NAV.zh[item.key]}
            </strong>
            <span aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    </div>

    <div class="menu-footer">
      <div class="language-control" aria-label="Language selector">
        <button type="button" class="lang-option active" data-lang-button="zh">中文</button>
        <button type="button" class="lang-option" data-lang-button="en">English</button>
        <button type="button" class="lang-option" data-lang-button="ru">Русский</button>
      </div>
      <a class="menu-mail" href="mailto:bd@hpf.kz">bd@hpf.kz</a>
    </div>
  </div>
</dialog>

<script>
  const menu = document.querySelector<HTMLDialogElement>("[data-site-menu]");
  const opener = document.querySelector<HTMLButtonElement>("[data-menu-open]");
  const closer = document.querySelector<HTMLButtonElement>("[data-menu-close]");

  const closeMenu = () => {
    menu?.close();
    opener?.setAttribute("aria-expanded", "false");
  };

  opener?.addEventListener("click", () => {
    menu?.showModal();
    opener.setAttribute("aria-expanded", "true");
    closer?.focus();
  });

  closer?.addEventListener("click", closeMenu);
  menu?.querySelectorAll("[data-menu-link]").forEach((link) => link.addEventListener("click", closeMenu));
  menu?.addEventListener("click", (event) => {
    if (event.target === menu) closeMenu();
  });
  menu?.addEventListener("close", () => opener?.setAttribute("aria-expanded", "false"));
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky-nav);
    border-bottom: var(--rule-hair) solid color-mix(in oklch, var(--color-rule), transparent 24%);
    background: color-mix(in oklch, var(--color-paper), transparent 7%);
    backdrop-filter: blur(1rem);
  }

  .nav-edge {
    display: flex;
    min-height: var(--banner-height);
    align-items: center;
    justify-content: space-between;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
  }

  .wordmark img {
    width: 6.25rem;
    height: auto;
  }

  .site-menu {
    width: 100%;
    max-width: none;
    height: 100%;
    max-height: none;
    margin: 0;
    padding: 0;
    border: 0;
    background: var(--color-ink);
    color: var(--color-paper);
  }

  .site-menu::backdrop {
    background: var(--color-overlay);
  }

  .menu-frame {
    display: grid;
    min-height: 100%;
    grid-template-rows: auto 1fr auto;
    padding-block: var(--space-lg);
  }

  .menu-topline,
  .menu-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .menu-brand,
  .menu-intro {
    margin: 0;
    color: var(--color-faint);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
  }

  .menu-close {
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    border: var(--rule-hair) solid var(--color-muted);
    border-radius: var(--radius-round);
    background: transparent;
    color: var(--color-paper);
    cursor: pointer;
    font-size: var(--text-xl);
    transition: transform var(--dur-medium) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
  }

  .menu-close:hover {
    border-color: var(--color-paper);
    transform: rotate(8deg);
  }

  .menu-body {
    display: grid;
    align-content: center;
    grid-template-columns: minmax(0, 0.32fr) minmax(0, 1fr);
    gap: var(--space-2xl);
    padding-block: var(--space-3xl);
  }

  .menu-index {
    border-top: var(--rule-hair) solid var(--color-ink-soft);
  }

  .menu-index a {
    display: grid;
    min-width: 0;
    grid-template-columns: 3rem minmax(0, 1fr) auto;
    align-items: baseline;
    gap: var(--space-md);
    padding-block: var(--space-sm);
    border-bottom: var(--rule-hair) solid var(--color-ink-soft);
    color: var(--color-paper-deep);
    transition: color var(--dur-fast) var(--ease-out), transform var(--dur-medium) var(--ease-out);
  }

  .menu-index a:hover,
  .menu-index a.current {
    color: var(--color-paper-soft);
    transform: translateX(var(--space-xs));
  }

  .menu-index a > span {
    color: var(--color-faint);
    font-size: var(--text-xs);
  }

  .menu-index strong {
    min-width: 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5.75rem);
    font-style: normal;
    font-weight: 400;
    letter-spacing: -0.035em;
    line-height: 0.95;
    overflow-wrap: anywhere;
  }

  .language-control {
    display: flex;
    gap: var(--space-xs);
  }

  .lang-option {
    padding-inline: var(--space-sm);
    color: var(--color-faint);
  }

  .lang-option.active {
    color: var(--color-paper-soft);
  }

  .menu-mail {
    color: var(--color-paper-soft);
    font-weight: 500;
    white-space: nowrap;
  }

  @media (max-width: 47.99rem) {
    .menu-body {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--space-xl);
      padding-block: var(--space-xl);
    }

    .menu-index a {
      grid-template-columns: 2rem minmax(0, 1fr) auto;
    }

    .menu-index strong {
      font-size: clamp(2.15rem, 12vw, 3.4rem);
    }

    .menu-footer {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
