---
import { COMPANY_NAME } from '../consts';
---

<header class="site-header">
  <nav class="site-nav" aria-label="Main navigation">
    <a class="brand-link" href="/" aria-label={`${COMPANY_NAME} home`}>
      <span class="brand-mark">HPF</span>
      <strong>{COMPANY_NAME}</strong>
    </a>

    <div class="nav-links">
      <a href="#operating-system">服务舱</a>
      <a href="#operating-system">路线网络</a>
      <a href="#operating-system">行业方案</a>
      <a href="#operating-system">平台能力</a>
    </div>

    <a class="nav-cta" href="#contact">配置路线</a>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 1000;
    border-bottom: 1px solid rgba(16, 20, 29, 0.1);
    background: rgba(255, 255, 255, 0.86);
    backdrop-filter: blur(18px);
  }

  .site-nav {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 24px;
    max-width: 1320px;
    height: 72px;
    margin: 0 auto;
    padding: 0 min(5vw, 72px);
  }

  .brand-link,
  .nav-links a,
  .nav-cta {
    color: #111318;
    text-decoration: none;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 17px;
    font-weight: 900;
  }

  .brand-mark {
    display: inline-grid;
    width: 38px;
    height: 38px;
    place-items: center;
    border-radius: 8px;
    background: #111318;
    color: #fff;
    font-size: 12px;
    font-weight: 900;
  }

  .nav-links {
    display: flex;
    justify-content: center;
    gap: clamp(18px, 3vw, 42px);
  }

  .nav-links a {
    font-size: 14px;
    font-weight: 800;
  }

  .nav-links a:hover {
    color: #d81324;
  }

  .nav-cta {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    justify-content: center;
    border: 1px solid #d81324;
    border-radius: 8px;
    background: #d81324;
    color: #fff;
    padding: 0 16px;
    font-size: 14px;
    font-weight: 900;
  }

  @media (max-width: 820px) {
    .site-nav {
      grid-template-columns: 1fr auto;
      height: auto;
      min-height: 66px;
      padding: 12px 22px;
    }

    .nav-links {
      grid-column: 1 / -1;
      order: 3;
      justify-content: flex-start;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 2px;
    }

    .nav-links a {
      flex: 0 0 auto;
      border: 1px solid rgba(16, 20, 29, 0.1);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.72);
      padding: 8px 10px;
      font-size: 13px;
    }
  }
</style>
