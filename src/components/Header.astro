---
import { COMPANY_NAME } from "../consts";
import type { NavKey } from "../site-content";

interface Props { active?: NavKey; }
const { active = "home" } = Astro.props;

const groups = [
  {
    key: "business",
    label: { zh: "业务能力", en: "Capabilities", ru: "Возможности" },
    links: [
      { href: "/services/#customs", key: "services", label: { zh: "清关与合规", en: "Customs & compliance", ru: "Таможня и соответствие" }, desc: { zh: "文件预审、HS 归类、证书与口岸协同", en: "File review, HS classification, certificates and border coordination", ru: "Проверка файлов, код ТН ВЭД, сертификаты и граница" } },
      { href: "/services/", key: "services", label: { zh: "运输与履约", en: "Transport & fulfilment", ru: "Перевозки и исполнение" }, desc: { zh: "TIR、仓储、干线与本地交付", en: "TIR, warehousing, linehaul and local delivery", ru: "TIR, склад, магистраль и местная доставка" } },
      { href: "/routes/", key: "routes", label: { zh: "路线网络", en: "Route network", ru: "Маршрутная сеть" }, desc: { zh: "中国、哈萨克斯坦与欧洲节点", en: "Nodes across China, Kazakhstan and Europe", ru: "Узлы Китая, Казахстана и Европы" } },
      { href: "/industries/", key: "industries", label: { zh: "行业方案", en: "Industries", ru: "Отрасли" }, desc: { zh: "按货物与业务约束配置方案", en: "Plans shaped around cargo and business constraints", ru: "Решения под груз и условия бизнеса" } },
    ],
  },
  {
    key: "operations",
    label: { zh: "运营体系", en: "Operations", ru: "Операции" },
    links: [
      { href: "/platform/", key: "platform", label: { zh: "运营平台", en: "Operating platform", ru: "Операционная платформа" }, desc: { zh: "节点、文件、费用与复盘台账", en: "Nodes, files, costs and review records", ru: "Узлы, документы, расходы и разбор" } },
      { href: "/news/", key: "news", label: { zh: "新闻动态", en: "News & updates", ru: "Новости" }, desc: { zh: "公司进展与路线现场判断", en: "Company progress and route intelligence", ru: "Развитие компании и данные маршрутов" } },
    ],
  },
  {
    key: "company",
    label: { zh: "公司", en: "Company", ru: "Компания" },
    links: [
      { href: "/about/", key: "about", label: { zh: "关于 HPF.kz", en: "About HPF.kz", ru: "О HPF.kz" }, desc: { zh: "哈萨克斯坦现场与中国上市公司体系", en: "Kazakhstan operations with a Chinese listed-company foundation", ru: "Работа в Казахстане и основа публичной группы из Китая" } },
      { href: "/contact/", key: "contact", label: { zh: "联系团队", en: "Contact the team", ru: "Связаться с командой" }, desc: { zh: "提交货物与路线要求", en: "Share cargo and routing requirements", ru: "Отправить данные груза и маршрута" } },
    ],
  },
] as const;
---

<header class="corporate-header">
  <div class="utility-rail">
    <div class="page-shell utility-inner">
      <span data-label-zh="阿拉木图 · 哈萨克斯坦" data-label-en="Almaty · Kazakhstan" data-label-ru="Алматы · Казахстан">阿拉木图 · 哈萨克斯坦</span>
      <a href="mailto:bd@hpf.kz">bd@hpf.kz</a>
    </div>
  </div>
  <div class="main-nav">
    <nav class="page-shell nav-inner" aria-label="Primary navigation">
      <a class="wordmark" href="/" aria-label={`${COMPANY_NAME} home`}>
        <img src="/brand/hpf-mark-dark.svg" alt="HPF KZ" width="160" height="64" />
      </a>

      <div class="desktop-nav">
        {groups.map((group) => (
          <details class="nav-group">
            <summary class:list={{ current: group.links.some((link) => link.key === active) }}>
              <span data-label-zh={group.label.zh} data-label-en={group.label.en} data-label-ru={group.label.ru}>{group.label.zh}</span>
              <span aria-hidden="true">⌄</span>
            </summary>
            <div class="mega-panel">
              <div class="mega-panel__inner page-shell">
                <p class="mega-title" data-label-zh={group.label.zh} data-label-en={group.label.en} data-label-ru={group.label.ru}>{group.label.zh}</p>
                <div class="mega-links">
                  {group.links.map((link) => (
                    <a href={link.href} class:list={{ current: link.key === active }}>
                      <strong data-label-zh={link.label.zh} data-label-en={link.label.en} data-label-ru={link.label.ru}>{link.label.zh}</strong>
                      <span data-label-zh={link.desc.zh} data-label-en={link.desc.en} data-label-ru={link.desc.ru}>{link.desc.zh}</span>
                    </a>
                  ))}
                </div>
                <div class="mega-promise">
                  <span>HPF.kz</span>
                  <p data-label-zh="每一程有安排，每一处有回音。" data-label-en="Every leg arranged. Every change answered." data-label-ru="Каждый этап организован. На каждое изменение есть ответ.">每一程有安排，每一处有回音。</p>
                </div>
              </div>
            </div>
          </details>
        ))}
      </div>

      <div class="nav-actions">
        <div class="language-control" aria-label="Language selector">
          <button type="button" class="lang-option active" data-lang-button="zh">中</button>
          <button type="button" class="lang-option" data-lang-button="en">EN</button>
          <button type="button" class="lang-option" data-lang-button="ru">RU</button>
        </div>
        <a class="nav-inquiry" href="/contact/" data-label-zh="运输询价" data-label-en="Freight enquiry" data-label-ru="Запрос перевозки">运输询价</a>
        <button class="mobile-toggle" type="button" data-mobile-open aria-controls="mobile-menu" aria-expanded="false">
          <span data-label-zh="菜单" data-label-en="Menu" data-label-ru="Меню">菜单</span>
        </button>
      </div>
    </nav>
  </div>
</header>

<dialog id="mobile-menu" class="mobile-menu" data-mobile-menu>
  <div class="mobile-menu__head">
    <img src="/brand/hpf-mark-dark.svg" alt="HPF KZ" width="160" height="64" />
    <button type="button" data-mobile-close aria-label="Close menu">×</button>
  </div>
  <nav class="mobile-menu__body" aria-label="Mobile navigation">
    {groups.map((group) => (
      <details>
        <summary data-label-zh={group.label.zh} data-label-en={group.label.en} data-label-ru={group.label.ru}>{group.label.zh}</summary>
        <div>
          {group.links.map((link) => (
            <a href={link.href} data-mobile-link>
              <strong data-label-zh={link.label.zh} data-label-en={link.label.en} data-label-ru={link.label.ru}>{link.label.zh}</strong>
              <span data-label-zh={link.desc.zh} data-label-en={link.desc.en} data-label-ru={link.desc.ru}>{link.desc.zh}</span>
            </a>
          ))}
        </div>
      </details>
    ))}
  </nav>
  <div class="mobile-menu__foot">
    <div class="mobile-languages" aria-label="Language selector">
      <button type="button" class="lang-option active" data-lang-button="zh">中文</button>
      <button type="button" class="lang-option" data-lang-button="en">English</button>
      <button type="button" class="lang-option" data-lang-button="ru">Русский</button>
    </div>
    <a href="mailto:bd@hpf.kz">bd@hpf.kz</a>
    <a class="button button--primary" href="/contact/" data-mobile-link data-label-zh="提交货运需求" data-label-en="Submit freight request" data-label-ru="Отправить запрос">提交货运需求</a>
  </div>
</dialog>

<script>
  const groups = Array.from(document.querySelectorAll<HTMLDetailsElement>(".nav-group"));
  groups.forEach((group) => group.addEventListener("toggle", () => {
    if (group.open) groups.filter((item) => item !== group).forEach((item) => item.removeAttribute("open"));
  }));
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") groups.forEach((item) => item.removeAttribute("open"));
  });

  const menu = document.querySelector<HTMLDialogElement>("[data-mobile-menu]");
  const opener = document.querySelector<HTMLButtonElement>("[data-mobile-open]");
  const closer = document.querySelector<HTMLButtonElement>("[data-mobile-close]");
  const closeMenu = () => { menu?.close(); opener?.setAttribute("aria-expanded", "false"); };
  opener?.addEventListener("click", () => { menu?.showModal(); opener.setAttribute("aria-expanded", "true"); closer?.focus(); });
  closer?.addEventListener("click", closeMenu);
  menu?.querySelectorAll("[data-mobile-link]").forEach((link) => link.addEventListener("click", closeMenu));
</script>

<style>
  .corporate-header { position: sticky; top: 0; z-index: var(--z-sticky-nav); }
  .utility-rail { min-height: var(--utility-height); background: var(--color-ink); color: var(--color-paper); }
  .utility-inner { display: flex; min-height: var(--utility-height); align-items: center; justify-content: space-between; gap: var(--space-md); color: var(--color-faint); font-size: var(--text-xs); }
  .utility-inner a { color: var(--color-paper); }
  .main-nav { border-bottom: var(--rule-hair) solid var(--color-rule); background: var(--color-paper); }
  .nav-inner { display: grid; grid-template-columns: 9rem minmax(0, 1fr) auto; align-items: center; min-height: var(--banner-height); gap: var(--space-lg); }
  .wordmark { display: inline-flex; align-items: center; }
  .wordmark img { width: 6.4rem; height: auto; }
  .desktop-nav { display: flex; align-self: stretch; justify-content: center; gap: var(--space-xs); }
  .nav-group { position: static; }
  .nav-group summary { display: flex; height: 100%; align-items: center; gap: var(--space-xs); padding-inline: var(--space-md); cursor: pointer; font-size: var(--text-sm); font-weight: 600; list-style: none; white-space: nowrap; }
  .nav-group summary::-webkit-details-marker { display: none; }
  .nav-group summary.current::after { position: absolute; bottom: 0; width: 1.5rem; height: var(--rule-strong); background: var(--color-accent); content: ""; }
  .nav-group[open] summary { color: var(--color-accent-deep); }
  .mega-panel { position: absolute; inset-inline: 0; top: 100%; border-bottom: var(--rule-hair) solid var(--color-rule); background: var(--color-paper); box-shadow: 0 1.5rem 2.5rem var(--color-overlay); }
  .mega-panel__inner { display: grid; grid-template-columns: .35fr 1.2fr .55fr; gap: var(--space-2xl); padding-block: var(--space-xl); }
  .mega-title { margin: 0; color: var(--color-muted); font-family: var(--font-outlier); font-size: var(--text-xs); letter-spacing: .08em; text-transform: uppercase; }
  .mega-links { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-sm); }
  .mega-links a { display: grid; gap: var(--space-xs); padding: var(--space-md); border: var(--rule-hair) solid var(--color-rule); }
  .mega-links a strong { font-size: var(--text-lg); }
  .mega-links a span { color: var(--color-muted); font-size: var(--text-sm); }
  .mega-links a.current { border-color: var(--color-accent); }
  .mega-promise { padding-inline-start: var(--space-lg); border-inline-start: var(--rule-hair) solid var(--color-rule); }
  .mega-promise span { color: var(--color-accent-deep); font-size: var(--text-xs); font-weight: 600; }
  .mega-promise p { max-width: 16ch; margin: var(--space-md) 0 0; font-size: var(--text-lg); font-weight: 600; }
  .nav-actions { display: flex; align-items: center; gap: var(--space-md); }
  .language-control { display: flex; align-items: center; }
  .lang-option { min-width: 2rem; padding: 0 var(--space-xs); color: var(--color-muted); font-size: var(--text-xs); }
  .lang-option.active { color: var(--color-ink); }
  .nav-inquiry { display: inline-flex; min-height: 2.75rem; align-items: center; padding-inline: var(--space-md); background: var(--color-ink); color: var(--color-paper); font-size: var(--text-sm); font-weight: 600; white-space: nowrap; }
  .mobile-toggle { display: none; min-height: 2.75rem; padding-inline: var(--space-md); border: var(--rule-hair) solid var(--color-rule-2); background: transparent; color: var(--color-ink); cursor: pointer; font-weight: 600; white-space: nowrap; }
  .mobile-menu { width: min(100%, 36rem); max-width: none; height: 100%; max-height: none; margin: 0 0 0 auto; padding: 0; border: 0; background: var(--color-paper); color: var(--color-ink); }
  .mobile-menu::backdrop { background: var(--color-overlay); }
  .mobile-menu[open] { display: grid; grid-template-rows: auto 1fr auto; }
  .mobile-menu__head { display: flex; min-height: var(--banner-height); align-items: center; justify-content: space-between; padding-inline: var(--space-md); border-bottom: var(--rule-hair) solid var(--color-rule); }
  .mobile-menu__head img { width: 6.4rem; height: auto; }
  .mobile-menu__head button { width: 2.75rem; height: 2.75rem; border: var(--rule-hair) solid var(--color-rule-2); background: transparent; font-size: var(--text-xl); }
  .mobile-menu__body { overflow-y: auto; padding: var(--space-lg) var(--space-md); }
  .mobile-menu__body details { border-bottom: var(--rule-hair) solid var(--color-rule); }
  .mobile-menu__body summary { padding-block: var(--space-lg); cursor: pointer; font-size: var(--text-lg); font-weight: 700; }
  .mobile-menu__body details > div { display: grid; padding-block-end: var(--space-lg); }
  .mobile-menu__body a { display: grid; gap: var(--space-2xs); padding: var(--space-sm); }
  .mobile-menu__body a span { color: var(--color-muted); font-size: var(--text-sm); }
  .mobile-menu__foot { display: grid; gap: var(--space-md); padding: var(--space-lg) var(--space-md) max(var(--space-lg), env(safe-area-inset-bottom)); border-top: var(--rule-hair) solid var(--color-rule); }
  .mobile-languages { display: flex; flex-wrap: wrap; gap: var(--space-xs); }
  .mobile-languages .lang-option { min-width: auto; padding-inline: var(--space-sm); border: var(--rule-hair) solid var(--color-rule); }
  @media (hover: hover) and (pointer: fine) { .mega-links a:hover { border-color: var(--color-ink); } .nav-inquiry:hover { background: var(--color-accent-deep); } }
  @media (max-width: 63.99rem) { .desktop-nav, .nav-inquiry { display: none; } .nav-inner { grid-template-columns: 1fr auto; } .mobile-toggle { display: inline-flex; align-items: center; } }
  @media (max-width: 39.99rem) { .utility-rail { display: none; } .language-control { display: none; } .nav-actions { gap: var(--space-sm); } }
</style>
