---
import { COMPANY_NAME, COMPANY_TAGLINE, COMPANY_TAGLINE_EN } from '../consts';
const today = new Date();
---

<footer class="site-footer">
  <div class="container">
    
    <!-- 主要内容区域 -->
    <div class="footer-content grid grid-4 gap-xl mb-5xl">
      
      <!-- 品牌信息 -->
      <div class="footer-brand">
        <div class="brand-logo mb-lg">
          <span class="logo-symbol chinese-text">{COMPANY_TAGLINE}</span>
          <div class="brand-info">
            <h3 class="brand-name chinese-text font-bold">{COMPANY_NAME}</h3>
            <p class="brand-tagline english-text small-element opacity-70">
              {COMPANY_TAGLINE_EN}
            </p>
          </div>
        </div>
        <p class="brand-description chinese-text opacity-80 mb-lg">
          我们不占位，也不喧哗。把力量藏在系统里，把答案写在时效上。你只需收货，其他交给我们。
        </p>
        <div class="contact-info">
          <div class="contact-item mb-sm">
            <span class="chinese-text font-medium">咨询邮箱：</span>
            <a href="mailto:contact@hpf.kz" class="contact-link">contact@hpf.kz</a>
          </div>
          <div class="contact-item">
            <span class="chinese-text font-medium">商务合作：</span>
            <a href="mailto:bd@hpf.kz" class="contact-link">bd@hpf.kz</a>
          </div>
        </div>
      </div>
      
      <!-- 服务项目 -->
      <div class="footer-section">
        <h4 class="section-title chinese-text font-bold mb-lg">核心能力</h4>
        <ul class="footer-links">
          <li><a href="#products" class="footer-link chinese-text">库雷克绿通</a></li>
          <li><a href="#products" class="footer-link chinese-text">清关合规</a></li>
          <li><a href="#products" class="footer-link chinese-text">仓储分拨</a></li>
          <li><a href="#products" class="footer-link chinese-text">干线联运</a></li>
        </ul>
      </div>
      
      <!-- 公司信息 -->
      <div class="footer-section">
        <h4 class="section-title chinese-text font-bold mb-lg">了解我们</h4>
        <ul class="footer-links">
          <li><a href="#about" class="footer-link chinese-text">关于我们</a></li>
          <li><a href="#about" class="footer-link chinese-text">企业文化</a></li>
          <li><a href="#about" class="footer-link chinese-text">发展历程</a></li>
          <li><a href="#contact" class="footer-link chinese-text">联系我们</a></li>
        </ul>
      </div>
      
      <!-- 联系方式 -->
      <div class="footer-section">
        <h4 class="section-title chinese-text font-bold mb-lg">联系我们</h4>
        <div class="contact-methods">
          <div class="contact-method mb-md">
            <div class="method-icon">📧</div>
            <div class="method-info">
              <div class="chinese-text font-medium">咨询邮箱</div>
              <a href="mailto:contact@hpf.kz" class="contact-link small-element">
                contact@hpf.kz
              </a>
            </div>
          </div>
          <div class="contact-method mb-md">
            <div class="method-icon">📱</div>
            <div class="method-info">
              <div class="chinese-text font-medium">商务合作</div>
              <a href="mailto:bd@hpf.kz" class="contact-link small-element">
                bd@hpf.kz
              </a>
            </div>
          </div>
          <div class="contact-method">
            <div class="method-icon">📍</div>
            <div class="method-info">
              <div class="chinese-text font-medium">总部地址</div>
              <span class="contact-text small-element">哈萨克斯坦 · 阿拉木图</span>
            </div>
          </div>
        </div>
      </div>
      
    </div>
    
    <!-- 底部分割线 -->
    <div class="footer-divider mb-xl"></div>
    
    <!-- 底部信息 -->
    <div class="footer-bottom">
      <div class="footer-bottom-content flex justify-between items-center">
        
        <!-- 版权信息 -->
        <div class="copyright">
          <p class="chinese-text opacity-70">
            &copy; {today.getFullYear()} {COMPANY_NAME}. 保留所有权利
          </p>
          <p class="english-text small-element opacity-60">
            All rights reserved. Powered by ancient wisdom and modern innovation.
          </p>
        </div>
        
        <!-- 道德经名句 -->
        <div class="philosophy-quote">
          <blockquote class="chinese-text font-medium opacity-80">
            「静水深流，润物无声」
          </blockquote>
          <cite class="english-text small-element opacity-60">
            — HPF.kz 运营格言
          </cite>
        </div>
        
      </div>
    </div>
    
  </div>
  
  <!-- 背景装饰 -->
  <div class="footer-decorations">
    <div class="decoration decoration-1"></div>
    <div class="decoration decoration-2"></div>
  </div>
</footer>

<style>
  .site-footer {
    background: 
      linear-gradient(135deg, rgba(22, 22, 21, 0.02) 0%, rgba(87, 81, 213, 0.03) 100%),
      radial-gradient(circle at 30% 70%, rgba(87, 81, 213, 0.05) 0%, transparent 50%);
    border-top: 1px solid rgba(22, 22, 21, 0.1);
    padding: var(--spacing-5xl) 0 var(--spacing-3xl);
    position: relative;
    overflow: hidden;
  }
  
  .footer-content {
    margin-bottom: var(--spacing-4xl);
  }
  
  /* 品牌信息 */
  .footer-brand {
    grid-column: span 2;
  }
  
  .brand-logo {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }
  
  .logo-symbol {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--accent-primary);
    padding: var(--spacing-sm) var(--spacing-md);
    border: 2px solid var(--accent-primary);
    border-radius: 6px;
    line-height: 1;
  }
  
  .brand-info {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }
  
  .brand-name {
    font-size: var(--text-lg);
    color: var(--text-primary);
    line-height: 1;
  }
  
  .brand-tagline {
    line-height: 1;
    letter-spacing: 0.05em;
  }
  
  .brand-description {
    line-height: 1.7;
    margin-bottom: var(--spacing-lg);
  }
  
  .contact-info {
    margin-top: var(--spacing-lg);
  }
  
  .contact-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }
  
  .contact-link {
    color: var(--accent-primary);
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.3s ease;
  }
  
  .contact-link:hover {
    opacity: 0.8;
  }
  
  /* 章节样式 */
  .footer-section {
    display: flex;
    flex-direction: column;
  }
  
  .section-title {
    color: var(--text-primary);
    margin-bottom: var(--spacing-lg);
  }
  
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .footer-links li {
    margin-bottom: var(--spacing-sm);
  }
  
  .footer-link {
    color: var(--text-primary);
    text-decoration: none;
    opacity: 0.8;
    transition: all 0.3s ease;
    font-weight: 400;
  }
  
  .footer-link:hover {
    color: var(--accent-primary);
    opacity: 1;
    transform: translateX(4px);
  }
  
  /* 联系方式样式 */
  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }
  
  .contact-method {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
  }
  
  .method-icon {
    font-size: var(--text-xl);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(87, 81, 213, 0.1);
    border-radius: 8px;
    flex-shrink: 0;
  }
  
  .method-info {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }
  
  .contact-text {
    color: var(--text-secondary);
  }
  
  /* 分割线 */
  .footer-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(22, 22, 21, 0.2) 50%, transparent 100%);
  }
  
  /* 底部信息 */
  .footer-bottom-content {
    align-items: flex-start;
  }
  
  .copyright {
    flex: 1;
  }
  
  .philosophy-quote {
    text-align: right;
    max-width: 300px;
  }
  
  .philosophy-quote blockquote {
    margin: 0 0 var(--spacing-xs) 0;
    font-size: var(--text-lg);
    line-height: 1.4;
  }
  
  /* 装饰性元素 */
  .footer-decorations {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    z-index: 1;
  }
  
  .decoration {
    position: absolute;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(87, 81, 213, 0.08) 0%, rgba(22, 22, 21, 0.03) 100%);
    filter: blur(40px);
  }
  
  .decoration-1 {
    width: 300px;
    height: 300px;
    top: 20%;
    right: 10%;
    animation: aurora-float 20s ease-in-out infinite;
  }
  
  .decoration-2 {
    width: 200px;
    height: 200px;
    bottom: 10%;
    left: 15%;
    animation: aurora-float 25s ease-in-out infinite reverse;
  }
  
  /* 响应式设计 */
  @media (max-width: 1024px) {
    .footer-content {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-2xl);
    }
    
    .footer-brand {
      grid-column: span 2;
      margin-bottom: var(--spacing-xl);
    }
  }
  
  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: var(--spacing-2xl);
    }
    
    .footer-brand {
      grid-column: span 1;
      margin-bottom: var(--spacing-lg);
    }
    
    .footer-bottom-content {
      flex-direction: column;
      gap: var(--spacing-xl);
      text-align: center;
    }
    
    .philosophy-quote {
      text-align: center;
      max-width: none;
    }
    
    .brand-logo {
      flex-direction: column;
      text-align: center;
      gap: var(--spacing-sm);
    }
  }
  
  @media (max-width: 480px) {
    .site-footer {
      padding: var(--spacing-3xl) 0 var(--spacing-2xl);
    }
    
    .brand-info {
      display: none;
    }
    
    .logo-symbol {
      font-size: var(--text-base);
      padding: var(--spacing-xs) var(--spacing-sm);
    }
    
    .contact-method {
      flex-direction: column;
      text-align: center;
      gap: var(--spacing-sm);
    }
  }
</style>