---
import { COMPANY_NAME, CONTACT_INFO } from '../consts';
---

<footer class="site-footer">
  <div class="footer-grid">
    <div class="footer-brand">
      <strong>{COMPANY_NAME}</strong>
      <p>
        确定性驱动的跨境物流价值传递。连接中国、哈萨克斯坦与欧洲，让路线、文件、库存和交付状态保持在同一张运营台账里。
      </p>
    </div>

    <div class="footer-column">
      <h2>服务</h2>
      <a href="#operating-system">库雷克绿通</a>
      <a href="#operating-system">EAEU合规</a>
      <a href="#operating-system">仓储分拨</a>
      <a href="#operating-system">多式联运</a>
    </div>

    <div class="footer-column">
      <h2>路线</h2>
      <a href="#operating-system">中国至阿拉木图</a>
      <a href="#operating-system">阿拉木图至库雷克</a>
      <a href="#operating-system">库雷克至巴库</a>
      <a href="#operating-system">欧洲末端交付</a>
    </div>

    <div class="footer-column">
      <h2>联系</h2>
      <a href={`mailto:${CONTACT_INFO.business}`}>{CONTACT_INFO.business}</a>
      <a href={`mailto:${CONTACT_INFO.email}`}>{CONTACT_INFO.email}</a>
      <span>{CONTACT_INFO.locationEn}</span>
      <span>{CONTACT_INFO.locationRu}</span>
    </div>
  </div>

  <div class="footer-bottom">
    <span>© 2026 {COMPANY_NAME}. All rights reserved.</span>
    <a href="#contact">Route request</a>
  </div>
</footer>

<style>
  .site-footer {
    background: #10141d;
    color: #fff;
    padding: 58px min(5vw, 72px) 28px;
  }

  .footer-grid,
  .footer-bottom {
    max-width: 1240px;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(260px, 1.5fr) repeat(3, 1fr);
    gap: 34px;
  }

  .footer-brand strong {
    display: block;
    font-size: 28px;
    line-height: 1;
  }

  .footer-brand p {
    max-width: 470px;
    margin-top: 18px;
    color: rgba(255, 255, 255, 0.64);
    line-height: 1.7;
  }

  .footer-column {
    display: grid;
    align-content: start;
    gap: 10px;
  }

  .footer-column h2 {
    margin: 0 0 8px;
    color: #fff;
    font-size: 14px;
    font-weight: 900;
  }

  .footer-column a,
  .footer-column span,
  .footer-bottom,
  .footer-bottom a {
    color: rgba(255, 255, 255, 0.64);
    text-decoration: none;
  }

  .footer-column a:hover,
  .footer-bottom a:hover {
    color: #fff;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    margin-top: 52px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-top: 24px;
    font-size: 14px;
  }

  @media (max-width: 860px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 560px) {
    .site-footer {
      padding-inline: 22px;
    }

    .footer-grid,
    .footer-bottom {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      display: grid;
    }
  }
</style>
