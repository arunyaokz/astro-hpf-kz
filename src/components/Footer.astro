---
import { getCollection } from "astro:content";
import { UI, pagePath, type CorePage, type Lang } from "../site-v2";

interface Props { lang?: Lang; }
const { lang = "en" } = Astro.props;
const ui = UI[lang];
const year = new Date().getFullYear();
const facts = await getCollection("facts");
const byId = new Map(facts.map((fact) => [fact.id, fact.data]));
const show = (id: string) => {
  const fact = byId.get(id);
  return fact?.verified ? fact.localizedValues?.[lang] ?? fact.value : `[${ui.pending}]`;
};
const navPages: CorePage[] = ["services", "routes", "about", "contact", "privacy"];
---

<footer class="footer">
  <div class="shell footer-grid">
    <div class="footer-brand">
      <img src="/brand/hpf-mark.svg" alt="HPF KZ" width="260" height="96" />
      <p>{ui.footerLine}</p>
      <a href="mailto:bd@hpf.kz">{show("business_email")}</a>
    </div>

    <nav aria-label="Footer navigation">
      {navPages.map((page) => <a href={pagePath(lang, page)}>{ui.nav[page]}</a>)}
    </nav>

    <dl class="legal-ledger">
      <div><dt>{byId.get("legal_name")?.labels[lang]}</dt><dd>{show("legal_name")}</dd></div>
      <div><dt>{byId.get("bin")?.labels[lang]}</dt><dd>{show("bin")}</dd></div>
      <div><dt>{byId.get("office_address")?.labels[lang]}</dt><dd><a href={byId.get("office_address")?.url} target="_blank" rel="noreferrer">{show("office_address")}</a></dd></div>
      <div><dt>{byId.get("business_phone")?.labels[lang]}</dt><dd>{show("business_phone")}</dd></div>
    </dl>
  </div>
  <div class="shell footer-bottom">
    <span>© {year} HPF.kz</span>
    <span>{ui.legalPending}</span>
  </div>
</footer>

<style>
  .footer { position: relative; overflow: hidden; background: #07041b; color: var(--text-on-dark); }
  .footer::before { position: absolute; width: 40rem; height: 24rem; inset: auto auto -16rem -8rem; border-radius: 50%; background: radial-gradient(circle,rgba(92,61,226,.28),transparent 70%); content: ""; }
  .footer-grid { position: relative; display: grid; grid-template-columns: minmax(16rem,.8fr) minmax(10rem,.4fr) minmax(20rem,1.1fr); gap: clamp(3rem,7vw,7rem); padding-block: clamp(5rem,8vw,8rem) 4rem; }
  .footer-brand { display: grid; align-content: start; justify-items: start; gap: 1.25rem; }
  .footer-brand img { width: 8.5rem; height: auto; }
  .footer-brand p { max-width: 23ch; color: var(--muted-on-dark); font-size: 1.05rem; }
  .footer-brand > a { color: #fff; font-size: 1.15rem; font-weight: 700; }
  .footer nav { display: grid; align-content: start; gap: .95rem; }
  .footer nav a { color: var(--muted-on-dark); font-size: .9rem; }
  .legal-ledger { margin: 0; }
  .legal-ledger div { display: grid; gap: .35rem; padding-block: .9rem; border-bottom: 1px solid rgba(255,255,255,.1); }
  .legal-ledger div:first-child { padding-block-start: 0; }
  .legal-ledger dt { color: rgba(255,255,255,.38); font-size: .7rem; }
  .legal-ledger dd { margin: 0; color: rgba(255,255,255,.78); font-family: var(--font-num); font-size: .74rem; line-height: 1.6; overflow-wrap: anywhere; }
  .legal-ledger dd a { transition: color 180ms var(--ease-out); }
  .footer-bottom { position: relative; display: flex; justify-content: space-between; gap: var(--space-2); padding-block: 1.35rem; border-top: 1px solid rgba(255,255,255,.1); color: rgba(255,255,255,.36); font-size: .7rem; }
  @media (hover:hover) and (pointer:fine) { .footer nav a:hover,.legal-ledger dd a:hover { color:#fff; } }
  @media (max-width:58rem) { .footer-grid { grid-template-columns: repeat(2,minmax(0,1fr)); } .legal-ledger { grid-column:1 / -1; display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:0 2rem; } }
  @media (max-width:38rem) { .footer-grid { grid-template-columns:1fr; } .legal-ledger { grid-column:auto; grid-template-columns:1fr; } .footer-bottom { flex-direction:column; } }
</style>
