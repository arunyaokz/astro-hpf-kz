---
import { CONTACT_INFO } from "../consts";
---

<footer class="statement-footer">
  <div class="page-shell footer-inner">
    <p
      class="footer-statement"
      data-label-zh="真正高级的物流，是让复杂从客户的视野里消失。"
      data-label-en="The finest logistics makes complexity disappear from the customer’s view."
      data-label-ru="Лучшая логистика скрывает сложность от клиента."
    >
      真正高级的物流，是让复杂从客户的视野里消失。
    </p>

    <div class="footer-meta">
      <div>
        <strong>HPF.KZ</strong>
        <span
          data-label-zh="中国—哈萨克斯坦—欧洲"
          data-label-en="China—Kazakhstan—Europe"
          data-label-ru="Китай—Казахстан—Европа"
        >中国—哈萨克斯坦—欧洲</span>
      </div>
      <div class="footer-contact">
        <a href={`mailto:${CONTACT_INFO.business}`}>{CONTACT_INFO.business}</a>
        <span>{CONTACT_INFO.locationEn}</span>
      </div>
      <span>© {new Date().getFullYear()} HPF.kz</span>
    </div>
  </div>
</footer>

<style>
  .statement-footer {
    border-top: var(--rule-hair) solid var(--color-rule);
    background: var(--color-ink);
    color: var(--color-paper);
  }

  .footer-inner {
    display: grid;
    gap: var(--space-4xl);
    padding-block: var(--space-4xl) var(--space-xl);
  }

  .footer-statement {
    max-width: 20ch;
    margin: 0;
    color: var(--color-paper);
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 7.5rem);
    font-style: normal;
    font-weight: 400;
    letter-spacing: -0.045em;
    line-height: 0.92;
    overflow-wrap: anywhere;
  }

  .footer-meta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) auto;
    align-items: end;
    gap: var(--space-xl);
    padding-top: var(--space-md);
    border-top: var(--rule-hair) solid var(--color-ink-soft);
    color: var(--color-faint);
    font-size: var(--text-sm);
  }

  .footer-meta div {
    display: grid;
    gap: var(--space-2xs);
  }

  .footer-meta strong,
  .footer-meta a {
    color: var(--color-paper-soft);
  }

  .footer-contact {
    justify-self: center;
  }

  @media (max-width: 47.99rem) {
    .footer-inner {
      gap: var(--space-3xl);
      padding-block-start: var(--space-3xl);
    }

    .footer-meta {
      grid-template-columns: minmax(0, 1fr);
      align-items: start;
    }

    .footer-contact {
      justify-self: start;
    }
  }
</style>
