---
import type { SiteLang } from "../site-content";

interface Props {
  lang: SiteLang;
  direction: string;
}

const { lang, direction } = Astro.props;
const labels: Record<SiteLang, Array<{ place: string; role: string }>> = {
  zh: [
    { place: "欧洲交付", role: "收货预约 / POD" },
    { place: "巴库", role: "里海西岸衔接" },
    { place: "库雷克", role: "跨里海节点" },
    { place: "阿拉木图", role: "仓配枢纽" },
    { place: "哈萨克斯坦入境", role: "口岸 / 清关" },
    { place: "中国集货", role: "工厂 / 集货" },
  ],
  en: [
    { place: "Europe delivery", role: "Appointment / POD" },
    { place: "Baku", role: "West Caspian transfer" },
    { place: "Kuryk", role: "Caspian node" },
    { place: "Almaty", role: "Fulfilment hub" },
    { place: "Kazakhstan entry", role: "Border / customs" },
    { place: "China origin", role: "Factory / consolidation" },
  ],
  ru: [
    { place: "Доставка в Европе", role: "Приёмка / POD" },
    { place: "Баку", role: "Западный берег Каспия" },
    { place: "Курык", role: "Каспийский узел" },
    { place: "Алматы", role: "Складской узел" },
    { place: "Въезд в Казахстан", role: "Граница / таможня" },
    { place: "Отправление из Китая", role: "Завод / консолидация" },
  ],
};
const points = [90, 295, 500, 705, 910, 1115];
---

<figure class="route-diagram">
  <div class="route-direction">
    <span aria-hidden="true">←</span>
    <span>{direction}</span>
  </div>
  <svg viewBox="0 0 1200 310" role="img" aria-label={direction}>
    <defs>
      <marker id={`route-arrow-${lang}`} markerWidth="10" markerHeight="10" refX="4" refY="3" orient="auto" markerUnits="strokeWidth">
        <path d="M0,0 L0,6 L6,3 z" />
      </marker>
    </defs>
    <path class="route-track" d="M1115 155 C1020 155 1000 118 910 134 C820 151 795 189 705 169 C625 151 584 118 500 139 C415 161 380 191 295 170 C216 151 176 137 90 155" marker-end={`url(#route-arrow-${lang})`} />
    <path class="caspian" d="M430 82 C475 55 520 61 553 93 C570 111 568 157 540 183 C505 216 455 212 426 177 C404 151 399 101 430 82Z" />
    {labels[lang].map((item, index) => (
      <g class:list={["route-node", { "route-node--hub": index === 3 }]}>
        <circle cx={points[index]} cy={index % 2 === 0 ? 155 : 170} r={index === 3 ? 9 : 7} />
        <line x1={points[index]} y1={index % 2 === 0 ? 155 : 170} x2={points[index]} y2={index % 2 === 0 ? 104 : 224} />
        <text class="route-place" x={points[index]} y={index % 2 === 0 ? 83 : 253} text-anchor="middle">{item.place}</text>
        <text class="route-role" x={points[index]} y={index % 2 === 0 ? 101 : 272} text-anchor="middle">{item.role}</text>
      </g>
    ))}
  </svg>
  <ol class="route-mobile">
    {labels[lang].map((item) => (
      <li>
        <strong>{item.place}</strong>
        <span>{item.role}</span>
      </li>
    ))}
  </ol>
</figure>

<style>
  .route-diagram { margin: 0; padding: var(--space-lg); border: var(--rule-hair) solid var(--color-rule); background: var(--color-paper); }
  .route-direction { display: flex; align-items: center; gap: var(--space-sm); color: var(--color-muted); font-size: var(--text-sm); }
  .route-direction > span:first-child { color: var(--color-accent); font-size: var(--text-lg); }
  svg { width: 100%; margin-block-start: var(--space-sm); overflow: visible; }
  .route-track { fill: none; stroke: var(--color-ink); stroke-width: 2.5; }
  marker path { fill: var(--color-accent); }
  .caspian { fill: var(--color-paper-2); stroke: var(--color-rule); stroke-width: 1; }
  .route-node circle { fill: var(--color-paper); stroke: var(--color-ink); stroke-width: 2; }
  .route-node--hub circle { fill: var(--color-accent); stroke: var(--color-accent); }
  .route-node line { stroke: var(--color-rule-2); stroke-width: 1; }
  .route-place { fill: var(--color-ink); font-family: var(--font-body); font-size: 15px; font-weight: 600; }
  .route-role { fill: var(--color-muted); font-family: var(--font-body); font-size: 11px; }
  .route-mobile { display: none; }
  @media (max-width: 47.99rem) {
    .route-diagram { padding: var(--space-md); }
    svg { display: none; }
    .route-mobile { display: grid; margin: var(--space-lg) 0 0; padding: 0; border-top: var(--rule-hair) solid var(--color-rule); list-style: none; }
    .route-mobile li { display: grid; grid-template-columns: minmax(0, 1fr); gap: var(--space-2xs); padding-block: var(--space-sm); border-bottom: var(--rule-hair) solid var(--color-rule); }
    .route-mobile li::before { content: "←"; color: var(--color-accent); }
    .route-mobile span { color: var(--color-muted); font-size: var(--text-sm); }
  }
</style>
