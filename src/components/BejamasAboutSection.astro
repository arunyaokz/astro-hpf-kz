---
import { TRANSLATIONS } from '../consts';

const t = TRANSLATIONS.zh;
---

<section class="bejamas-section bejamas-base">
  <div class="bejamas-container">
    <div class="bejamas-about-grid">
      <div class="bejamas-about-content">
        <div class="bejamas-section-header">
          <h2 class="bejamas-title-2xl bejamas-heading">{t.aboutTitle}</h2>
          <p class="bejamas-subtitle bejamas-mt-2">专业的跨境物流服务提供商</p>
        </div>
        
        <div class="bejamas-about-text">
          <p class="bejamas-text-lg">
            HPF.kz 是一家专注于中国与哈萨克斯坦之间跨境物流的专业服务商。
            我们致力于为客户提供高效、可靠、安全的物流解决方案。
          </p>
          
          <div class="bejamas-about-features">
            <div class="bejamas-feature-item">
              <div class="bejamas-feature-icon bejamas-bg-blue-100">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M8 12H16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M12 8V16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="bejamas-feature-content">
                <h4 class="bejamas-title-md">专业团队</h4>
                <p class="bejamas-text-sm">拥有经验丰富的物流专家和本地化服务团队</p>
              </div>
            </div>
            
            <div class="bejamas-feature-item">
              <div class="bejamas-feature-icon bejamas-bg-green-100">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 8V12L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 21C16.9706 21 21 16.9706 21 12C21 7.02944 16.9706 3 12 3C7.02944 3 3 7.02944 3 12C3 16.9706 7.02944 21 12 21Z" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              </div>
              <div class="bejamas-feature-content">
                <h4 class="bejamas-title-md">高效时效</h4>
                <p class="bejamas-text-sm">优化的运输路线和流程，确保货物准时到达</p>
              </div>
            </div>
            
            <div class="bejamas-feature-item">
              <div class="bejamas-feature-icon bejamas-bg-purple-100">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 15C13.6569 15 15 13.6569 15 12C15 10.3431 13.6569 9 12 9C10.3431 9 9 10.3431 9 12C9 13.6569 10.3431 15 12 15Z" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M17 7L19 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M19 12H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M17 17L19 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 19V21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M7 17L5 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M5 12H3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M7 7L5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 5V3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="bejamas-feature-content">
                <h4 class="bejamas-title-md">全程跟踪</h4>
                <p class="bejamas-text-sm">实时货物追踪系统，让您随时了解运输状态</p>
              </div>
            </div>
            
            <div class="bejamas-feature-item">
              <div class="bejamas-feature-icon bejamas-bg-yellow-100">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9 12L11 14L15 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 3V12M12 21V12M12 12L21 12M12 12L3 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="bejamas-feature-content">
                <h4 class="bejamas-title-md">定制方案</h4>
                <p class="bejamas-text-sm">根据客户需求提供个性化的物流解决方案</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="bejamas-about-stats">
          <div class="bejamas-stat">
            <h3 class="bejamas-stat-number">5+</h3>
            <p class="bejamas-stat-label">年行业经验</p>
          </div>
          <div class="bejamas-stat">
            <h3 class="bejamas-stat-number">1000+</h3>
            <p class="bejamas-stat-label">成功项目</p>
          </div>
          <div class="bejamas-stat">
            <h3 class="bejamas-stat-number">98%</h3>
            <p class="bejamas-stat-label">客户满意度</p>
          </div>
          <div class="bejamas-stat">
            <h3 class="bejamas-stat-number">24/7</h3>
            <p class="bejamas-stat-label">客户支持</p>
          </div>
        </div>
      </div>
      
      <div class="bejamas-about-visual">
        <div class="bejamas-visual-card">
          <div class="bejamas-visual-image">
            <img src="/api/placeholder/400/300" alt="物流团队" />
          </div>
          <div class="bejamas-visual-content">
            <h4 class="bejamas-title-md">我们的使命</h4>
            <p class="bejamas-text-sm">通过专业的物流服务，连接中国与哈萨克斯坦的贸易往来，为客户创造价值。</p>
          </div>
        </div>
        
        <div class="bejamas-visual-card">
          <div class="bejamas-visual-image">
            <img src="/api/placeholder/400/300" alt="运输网络" />
          </div>
          <div class="bejamas-visual-content">
            <h4 class="bejamas-title-md">我们的愿景</h4>
            <p class="bejamas-text-sm">成为中亚地区最值得信赖的跨境物流服务提供商。</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bejamas-about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--bejamas-space-12);
    align-items: start;
  }
  
  @media (min-width: 1024px) {
    .bejamas-about-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  
  .bejamas-about-content {
    display: flex;
    flex-direction: column;
    gap: var(--bejamas-space-8);
  }
  
  .bejamas-about-features {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--bejamas-space-6);
  }
  
  @media (min-width: 640px) {
    .bejamas-about-features {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  .bejamas-feature-item {
    display: flex;
    align-items: flex-start;
    gap: var(--bejamas-space-4);
  }
  
  .bejamas-feature-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--bejamas-radius-lg);
    color: var(--bejamas-color-accent);
    flex-shrink: 0;
  }
  
  .bejamas-feature-content {
    flex: 1;
  }
  
  .bejamas-about-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--bejamas-space-6);
    margin-top: var(--bejamas-space-8);
  }
  
  @media (min-width: 640px) {
    .bejamas-about-stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  .bejamas-stat {
    text-align: center;
    padding: var(--bejamas-space-4);
    background-color: var(--bejamas-color-surface);
    border: 1px solid var(--bejamas-color-border);
    border-radius: var(--bejamas-radius-lg);
  }
  
  .bejamas-stat-number {
    font-size: var(--bejamas-text-2xl);
    font-weight: 700;
    color: var(--bejamas-color-accent);
    margin-bottom: var(--bejamas-space-1);
  }
  
  .bejamas-stat-label {
    color: var(--bejamas-color-text-muted);
    font-size: var(--bejamas-text-sm);
    font-weight: 500;
  }
  
  .bejamas-about-visual {
    display: flex;
    flex-direction: column;
    gap: var(--bejamas-space-6);
  }
  
  .bejamas-visual-card {
    background-color: var(--bejamas-color-surface);
    border: 1px solid var(--bejamas-color-border);
    border-radius: var(--bejamas-radius-xl);
    overflow: hidden;
    transition: all var(--bejamas-transition-base);
  }
  
  .bejamas-visual-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--bejamas-shadow-lg);
  }
  
  .bejamas-visual-image {
    width: 100%;
    height: 200px;
    background-color: var(--bejamas-color-bg-muted);
    overflow: hidden;
  }
  
  .bejamas-visual-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .bejamas-visual-content {
    padding: var(--bejamas-space-6);
  }
  
  /* Color variants */
  .bejamas-bg-blue-100 {
    background-color: rgba(59, 130, 246, 0.1);
    color: var(--bejamas-color-blue-600);
  }
  
  .bejamas-bg-green-100 {
    background-color: rgba(16, 185, 129, 0.1);
    color: var(--bejamas-color-green-600);
  }
  
  .bejamas-bg-purple-100 {
    background-color: rgba(139, 92, 246, 0.1);
    color: var(--bejamas-color-purple-600);
  }
  
  .bejamas-bg-yellow-100 {
    background-color: rgba(245, 158, 11, 0.1);
    color: var(--bejamas-color-yellow-600);
  }
  
  /* Spacing utilities */
  .bejamas-mt-2 { margin-top: var(--bejamas-space-2); }
  .bejamas-mt-8 { margin-top: var(--bejamas-space-8); }
</style>