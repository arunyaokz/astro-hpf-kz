---
import { TRANSLATIONS } from '../consts';

const t = TRANSLATIONS.zh;
---

<section class="bejamas-section bejamas-base">
  <div class="bejamas-container">
    <div class="bejamas-section-header bejamas-text-center">
      <h2 class="bejamas-title-2xl bejamas-heading">{t.productsTitle}</h2>
      <p class="bejamas-subtitle bejamas-mt-2">端到端物流解决方案，覆盖全链路关键环节</p>
    </div>
    
    <div class="bejamas-grid bejamas-grid-cols-1 md:bejamas-grid-cols-2 lg:bejamas-grid-cols-3 bejamas-gap-8">
      <div class="bejamas-product-card">
        <div class="bejamas-product-badge">核心产品</div>
        <div class="bejamas-product-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 7V10C2 16 12 22 12 22C12 22 22 16 22 10V7L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M12 8V12L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">{t.kurekGreen}</h3>
        <p class="bejamas-text-base bejamas-text-muted">{t.kurekGreenDesc}</p>
        <ul class="bejamas-feature-list">
          <li>港口协同排期</li>
          <li>舱位协调保障</li>
          <li>优先通行权限</li>
          <li>实时状态追踪</li>
        </ul>
      </div>
      
      <div class="bejamas-product-card">
        <div class="bejamas-product-badge">合规服务</div>
        <div class="bejamas-product-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 11L12 14L22 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M21 12V19C21 19.5304 20.7893 20.0391 20.4142 20.4142C20.0391 20.7893 19.5304 21 19 21H5C4.46957 21 3.96086 20.7893 3.58579 20.4142C3.21071 20.0391 3 19.5304 3 19V5C3 4.46957 3.21071 3.96086 3.58579 3.58579C3.96086 3.21071 4.46957 3 5 3H16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">{t.customsClearance}</h3>
        <p class="bejamas-text-base bejamas-text-muted">{t.customsClearanceDesc}</p>
        <ul class="bejamas-feature-list">
          <li>EAEU技术法规对接</li>
          <li>多语言文档处理</li>
          <li>合规风险评估</li>
          <li>快速清关通道</li>
        </ul>
      </div>
      
      <div class="bejamas-product-card">
        <div class="bejamas-product-badge">仓储服务</div>
        <div class="bejamas-product-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 9H21V21C21 21.2652 20.8946 21.5196 20.7071 21.7071C20.5196 21.8946 20.2652 22 20 22H4C3.73478 22 3.48043 21.8946 3.29289 21.7071C3.10536 21.5196 3 21.2652 3 21V9Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M21 9V5C21 4.46957 20.7893 3.96086 20.4142 3.58579C20.0391 3.21071 19.5304 3 19 3H5C4.46957 3 3.96086 3.21071 3.58579 3.58579C3.21071 3.96086 3 4.46957 3 5V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M9 9V3H15V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">{t.warehousing}</h3>
        <p class="bejamas-text-base bejamas-text-muted">{t.warehousingDesc}</p>
        <ul class="bejamas-feature-list">
          <li>保税/普通/温控仓储</li>
          <li>SKU级可视化库存</li>
          <li>智能分拣系统</li>
          <li>库存预警管理</li>
        </ul>
      </div>
      
      <div class="bejamas-product-card">
        <div class="bejamas-product-badge">运输服务</div>
        <div class="bejamas-product-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M16 8H20L22 11V16H16M16 8V16M16 8H8M16 16H8M8 16H4M8 16V8M8 8H4M8 8V4C8 3.46957 8.21071 2.96086 8.58579 2.58579C8.96086 2.21071 9.46957 2 10 2H14C14.5304 2 15.0391 2.21071 15.4142 2.58579C15.7893 2.96086 16 3.46957 16 4V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="8" cy="18" r="2" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="18" cy="18" r="2" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">{t.transport}</h3>
        <p class="bejamas-text-base bejamas-text-muted">{t.transportDesc}</p>
        <ul class="bejamas-feature-list">
          <li>海/铁/公/空多式联运</li>
          <li>路径优化算法</li>
          <li>实时位置追踪</li>
          <li>异常预警系统</li>
        </ul>
      </div>
      
      <div class="bejamas-product-card">
        <div class="bejamas-product-badge">配送服务</div>
        <div class="bejamas-product-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 7V10C2 16 12 22 12 22C12 22 22 16 22 10V7L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M9 12L11 14L15 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">{t.lastMile}</h3>
        <p class="bejamas-text-base bejamas-text-muted">{t.lastMileDesc}</p>
        <ul class="bejamas-feature-list">
          <li>B2B专业配送</li>
          <li>电商逆向闭环</li>
          <li>签收确认系统</li>
          <li>客户满意度追踪</li>
        </ul>
      </div>
      
      <div class="bejamas-product-card">
        <div class="bejamas-product-badge">金融服务</div>
        <div class="bejamas-product-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="6" width="18" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3 10H21" stroke="currentColor" stroke-width="1.5"/>
            <path d="M7 14H10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M14 14H17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">{t.financial}</h3>
        <p class="bejamas-text-base bejamas-text-muted">{t.financialDesc}</p>
        <ul class="bejamas-feature-list">
          <li>货物运输保险</li>
          <li>多币种结算</li>
          <li>供应链金融</li>
          <li>资金流优化</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .bejamas-product-card {
    background-color: var(--bejamas-color-surface);
    border: 1px solid var(--bejamas-color-border);
    border-radius: var(--bejamas-radius-xl);
    padding: var(--bejamas-space-8);
    transition: all var(--bejamas-transition-base);
    height: 100%;
    position: relative;
  }
  
  .bejamas-product-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--bejamas-shadow-lg);
  }
  
  .bejamas-product-badge {
    position: absolute;
    top: var(--bejamas-space-4);
    right: var(--bejamas-space-4);
    background-color: var(--bejamas-color-accent);
    color: white;
    padding: var(--bejamas-space-1) var(--bejamas-space-3);
    border-radius: var(--bejamas-radius-full);
    font-size: var(--bejamas-text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .bejamas-product-icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(99, 102, 241, 0.1);
    border-radius: var(--bejamas-radius-lg);
    color: var(--bejamas-color-accent);
    margin-bottom: var(--bejamas-space-4);
  }
  
  .bejamas-feature-list {
    list-style: none;
    padding: 0;
    margin: var(--bejamas-space-4) 0 0 0;
  }
  
  .bejamas-feature-list li {
    position: relative;
    padding-left: var(--bejamas-space-4);
    margin-bottom: var(--bejamas-space-2);
    font-size: var(--bejamas-text-sm);
    color: var(--bejamas-color-text-secondary);
  }
  
  .bejamas-feature-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    background-color: var(--bejamas-color-accent);
    border-radius: 50%;
  }
  
  /* Responsive design */
  @media (min-width: 768px) {
    .md\:bejamas-grid-cols-2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .lg\:bejamas-grid-cols-3 {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .bejamas-gap-8 {
    gap: var(--bejamas-space-8);
  }
</style>