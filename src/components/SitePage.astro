---
import { CONTACT_INFO } from "../consts";
import { SITE_LANGS, SITE_PAGES, TRUST_NARRATIVE, type PageKey, type SiteLang } from "../site-content";
import RouteDiagram from "./RouteDiagram.astro";

interface Props { pageKey: PageKey; }
const { pageKey } = Astro.props;
const pageSet = SITE_PAGES[pageKey];
const actionHref = pageKey === "contact" ? `mailto:${CONTACT_INFO.business}` : "/contact/";
const image = pageKey === "services" || pageKey === "platform" ? "/images/corporate/warehouse-operations.jpg" : "/images/corporate/truck-mountains.jpg";
const imageSize = image.includes("warehouse") ? { width: 1600, height: 1067 } : { width: 1800, height: 2700 };

const ui: Record<SiteLang, { foundation: string; scope: string; process: string; imageNote: string; routeDirection: string; contact: string }> = {
  zh: { foundation: "运营基础", scope: "能力范围", process: "工作次序", imageNote: "行业场景图，不代表 HPF.kz 自有资产", routeDirection: "货物流向：由右向左，中国 → 欧洲", contact: "提交货运需求" },
  en: { foundation: "Operating foundation", scope: "Scope of capability", process: "Operating sequence", imageNote: "Industry image; not an HPF.kz-owned asset", routeDirection: "Cargo direction: right to left, China → Europe", contact: "Submit freight request" },
  ru: { foundation: "Операционная основа", scope: "Объём возможностей", process: "Порядок работы", imageNote: "Отраслевое фото; это не актив HPF.kz", routeDirection: "Направление груза: справа налево, Китай → Европа", contact: "Отправить запрос" },
};
---

<div class="corporate-page" data-language-root={pageKey}>
  {SITE_LANGS.map((lang) => {
    const page = pageSet[lang];
    const trust = TRUST_NARRATIVE[lang];
    const labels = ui[lang];
    return (
      <article class:list={["localized-page", { active: lang === "zh" }]} data-lang-panel={lang} data-page-key={pageKey}>
        <section class="subpage-hero page-shell">
          <div class="subpage-hero__copy">
            <p class="overline">HPF.kz · {page.visualLabel}</p>
            <h1 class="display-title">{page.title}</h1>
            <p class="body-copy">{page.lead}</p>
            <div class="subpage-actions">
              <a class="button button--primary" href={actionHref}>{page.primaryAction}</a>
              <a class="button button--secondary" href="/routes/">{page.secondaryAction}</a>
            </div>
          </div>
          <figure>
            <img src={image} alt={pageSet.imageAlt[lang]} width={imageSize.width} height={imageSize.height} fetchpriority="high" />
            <figcaption>{labels.imageNote}</figcaption>
          </figure>
        </section>

        <section class="foundation page-shell">
          <header>
            <p class="overline">{labels.foundation}</p>
            <h2>{trust.title}</h2>
            <p>{trust.text}</p>
          </header>
          <div class="foundation-list">
            {trust.items.map((item, index) => (
              <div><span>{String(index + 1).padStart(2, "0")}</span><strong>{item.value}</strong><p>{item.label} · {item.note}</p></div>
            ))}
          </div>
        </section>

        {pageKey === "routes" && (
          <section class="route-feature">
            <div class="page-shell">
              <RouteDiagram lang={lang} direction={labels.routeDirection} />
            </div>
          </section>
        )}

        <section class="scope-section page-shell">
          <header><p class="overline">{labels.scope}</p><h2>{page.sectionsTitle}</h2></header>
          <div class="scope-list">
            {page.sections.map((section, index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <div><h3>{section.title}</h3><p>{section.text}</p></div>
                <ul>{section.bullets.map((bullet) => <li>{bullet}</li>)}</ul>
              </article>
            ))}
          </div>
        </section>

        <section class="operating-section">
          <div class="page-shell operating-layout">
            <header><p class="overline">{page.panelsTitle}</p><h2>{page.panels[0]?.title}</h2><p>{page.panels[0]?.text}</p></header>
            <div class="operating-cases">
              {page.panels.map((panel) => (
                <article><strong>{panel.label}</strong><h3>{panel.title}</h3><p>{panel.text}</p><ul>{panel.points.map((point) => <li>{point}</li>)}</ul></article>
              ))}
            </div>
          </div>
        </section>

        <section class="sequence-section page-shell">
          <header><p class="overline">{labels.process}</p><h2>{page.timelineTitle}</h2></header>
          <ol>
            {page.timeline.map((item) => (
              <li><span>{item.step}</span><h3>{item.title}</h3><p>{item.text}</p></li>
            ))}
          </ol>
        </section>

        <section class="page-cta">
          <div class="page-shell">
            <div><h2>{page.ctaTitle}</h2><p>{page.ctaText}</p></div>
            <a class="button button--light" href={actionHref}>{page.ctaButton || labels.contact}</a>
          </div>
        </section>
      </article>
    );
  })}
</div>

<style>
  .subpage-hero { display: grid; min-width: 0; grid-template-columns: minmax(0, 1.15fr) minmax(20rem, .85fr); gap: var(--space-3xl); align-items: stretch; padding-block: var(--space-xl) var(--space-2xl); }
  .subpage-hero__copy { display: flex; min-width: 0; flex-direction: column; align-items: flex-start; justify-content: center; gap: var(--space-lg); padding-block: var(--space-md); }
  .subpage-hero .display-title { max-width: 12ch; }
  .subpage-actions { display: flex; flex-wrap: wrap; gap: var(--space-sm); }
  .subpage-hero figure { min-width: 0; min-height: 30rem; margin: 0; }
  .subpage-hero figure img { width: 100%; height: 100%; max-height: 42rem; object-fit: cover; }
  figure figcaption { padding-block-start: var(--space-xs); color: var(--color-muted); font-size: var(--text-xs); }
  .foundation { display: grid; grid-template-columns: minmax(18rem, .7fr) minmax(0, 1.3fr); gap: var(--space-3xl); padding-block: var(--space-4xl); }
  .foundation header { display: grid; align-content: start; gap: var(--space-lg); }
  .foundation h2, .scope-section h2, .operating-section h2, .sequence-section h2 { margin: 0; font-size: clamp(2.25rem, 4.5vw, 4.75rem); line-height: 1.08; letter-spacing: -.035em; }
  .foundation header > p:last-child, .operating-section header > p:last-child { margin: 0; color: var(--color-muted); }
  .foundation-list { border-top: var(--rule-strong) solid var(--color-ink); }
  .foundation-list > div { display: grid; grid-template-columns: 2.5rem minmax(11rem, .65fr) minmax(0, 1fr); gap: var(--space-lg); padding-block: var(--space-lg); border-bottom: var(--rule-hair) solid var(--color-rule); }
  .foundation-list span { color: var(--color-accent-deep); font-size: var(--text-sm); font-variant-numeric: tabular-nums; }
  .foundation-list p { margin: 0; color: var(--color-muted); }
  .route-feature { padding-block: var(--space-3xl); background: var(--color-paper-2); }
  .scope-section { display: grid; grid-template-columns: minmax(16rem, .55fr) minmax(0, 1.45fr); gap: var(--space-3xl); padding-block: var(--space-4xl); }
  .scope-section header { display: grid; align-content: start; gap: var(--space-lg); }
  .scope-list { border-top: var(--rule-strong) solid var(--color-ink); }
  .scope-list article { display: grid; grid-template-columns: 2.5rem minmax(0, 1fr) minmax(10rem, .45fr); gap: var(--space-lg); padding-block: var(--space-xl); border-bottom: var(--rule-hair) solid var(--color-rule); }
  .scope-list article > span { color: var(--color-accent-deep); font-variant-numeric: tabular-nums; }
  .scope-list h3, .scope-list p, .scope-list ul { margin: 0; }
  .scope-list h3 { font-size: var(--text-lg); }
  .scope-list p { margin-block-start: var(--space-sm); color: var(--color-muted); }
  .scope-list ul { padding-inline-start: var(--space-lg); color: var(--color-ink-2); }
  .operating-section { background: var(--color-ink); color: var(--color-paper); }
  .operating-layout { display: grid; grid-template-columns: minmax(17rem, .6fr) minmax(0, 1.4fr); gap: var(--space-3xl); padding-block: var(--space-4xl); }
  .operating-section header { display: grid; align-content: start; gap: var(--space-lg); }
  .operating-section .overline { color: var(--color-accent); }
  .operating-section h2 { color: var(--color-paper); }
  .operating-cases { border-top: var(--rule-hair) solid var(--color-muted); }
  .operating-cases article { display: grid; grid-template-columns: 6rem minmax(10rem, .55fr) minmax(0, 1fr); gap: var(--space-lg); padding-block: var(--space-lg); border-bottom: var(--rule-hair) solid var(--color-ink-2); }
  .operating-cases strong { color: var(--color-accent); font-size: var(--text-sm); }
  .operating-cases h3, .operating-cases p, .operating-cases ul { margin: 0; }
  .operating-cases p, .operating-cases ul { color: var(--color-faint); }
  .operating-cases ul { padding-inline-start: var(--space-lg); }
  .sequence-section { display: grid; grid-template-columns: minmax(16rem, .55fr) minmax(0, 1.45fr); gap: var(--space-3xl); padding-block: var(--space-4xl); }
  .sequence-section header { display: grid; align-content: start; gap: var(--space-lg); }
  .sequence-section ol { margin: 0; padding: 0; border-top: var(--rule-strong) solid var(--color-ink); list-style: none; }
  .sequence-section li { display: grid; grid-template-columns: 3rem minmax(10rem, .5fr) minmax(0, 1fr); gap: var(--space-lg); padding-block: var(--space-lg); border-bottom: var(--rule-hair) solid var(--color-rule); }
  .sequence-section li span { color: var(--color-accent-deep); font-variant-numeric: tabular-nums; }
  .sequence-section h3, .sequence-section p { margin: 0; }
  .sequence-section p { color: var(--color-muted); }
  .page-cta { background: var(--color-ink); color: var(--color-paper); }
  .page-cta > div { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: var(--space-xl); align-items: end; padding-block: var(--space-3xl); }
  .page-cta h2 { max-width: 18ch; margin: 0; font-size: clamp(2.5rem, 5vw, 5rem); line-height: 1.05; letter-spacing: -.035em; }
  .page-cta p { max-width: 58ch; margin: var(--space-lg) 0 0; }
  @media (max-width: 59.99rem) { .subpage-hero, .foundation, .scope-section, .operating-layout, .sequence-section { grid-template-columns: minmax(0, 1fr); } .subpage-hero { grid-template-columns: minmax(0, 1.05fr) minmax(18rem, .95fr); } }
  @media (max-width: 39.99rem) {
    .subpage-hero { grid-template-columns: minmax(0, 1fr); padding-block: var(--space-lg) var(--space-2xl); }
    .subpage-hero figure { min-height: 25rem; }
    .foundation, .scope-section, .operating-layout, .sequence-section { padding-block: var(--space-3xl); }
    .foundation-list > div { grid-template-columns: 2rem minmax(0, 1fr); }
    .foundation-list p { grid-column: 2; }
    .scope-list article { grid-template-columns: 2rem minmax(0, 1fr); }
    .scope-list ul { grid-column: 2; }
    .operating-cases article { grid-template-columns: minmax(0, 1fr); }
    .sequence-section li { grid-template-columns: 2rem minmax(0, 1fr); }
    .sequence-section p { grid-column: 2; }
    .page-cta > div { grid-template-columns: minmax(0, 1fr); align-items: start; }
  }
</style>
