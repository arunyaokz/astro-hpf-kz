---
import { CONTACT_INFO } from "../consts";
import { SITE_LANGS, SITE_PAGES, TRUST_NARRATIVE, type PageKey, type SiteLang } from "../site-content";

interface Props {
  pageKey: PageKey;
}

const { pageKey } = Astro.props;
const pageSet = SITE_PAGES[pageKey];
const actionHref = pageKey === "contact" ? `mailto:${CONTACT_INFO.business}` : "/contact/";
const secondaryHref = pageKey === "services" ? "/routes/" : "/services/";

const labels: Record<SiteLang, {
  network: string;
  networkNote: string;
  rail: string;
  sea: string;
  road: string;
  proof: string;
  capabilities: string;
  operating: string;
  routeAction: string;
  cities: [string, string, string, string, string];
}> = {
  zh: {
    network: "一张可执行的中亚履约网络",
    networkNote: "铁路、公路、里海与仓配节点被放进同一条责任链。点击节点查看对应能力。",
    rail: "铁路 / 公路",
    sea: "里海轮渡",
    road: "TIR / 末端",
    proof: "信任不是口号，是可核验的资源结构",
    capabilities: "把资产组织成交付能力",
    operating: "按场景查看运营边界",
    routeAction: "查看完整路线",
    cities: ["中国集货", "阿拉木图", "库雷克港", "巴库", "欧洲交付"],
  },
  en: {
    network: "An executable Central Asia delivery network",
    networkNote: "Rail, road, Caspian and fulfilment nodes sit inside one chain of accountability. Select a node to inspect the capability.",
    rail: "Rail / road",
    sea: "Caspian ferry",
    road: "TIR / final mile",
    proof: "Trust is a verifiable resource structure",
    capabilities: "Turning assets into delivery capability",
    operating: "Inspect the operating boundary by scenario",
    routeAction: "Explore the full route",
    cities: ["China origin", "Almaty", "Kuryk Port", "Baku", "Europe delivery"],
  },
  ru: {
    network: "Исполнимая сеть доставки по Центральной Азии",
    networkNote: "ЖД, авто, Каспий и складские узлы объединены одной цепочкой ответственности. Выберите узел, чтобы увидеть возможности.",
    rail: "ЖД / авто",
    sea: "Каспийский паром",
    road: "TIR / доставка",
    proof: "Доверие — это проверяемая структура ресурсов",
    capabilities: "Превращаем активы в исполнение",
    operating: "Границы работы по сценарию",
    routeAction: "Вся маршрутная сеть",
    cities: ["Отправление Китай", "Алматы", "Порт Курык", "Баку", "Доставка Европа"],
  },
};
---

<div class:list={["site-page", { "is-home": pageKey === "home" }]} data-language-root={pageKey}>
  {SITE_LANGS.map((lang) => {
    const page = pageSet[lang];
    const trust = TRUST_NARRATIVE[lang];
    const ui = labels[lang];

    return (
      <article class:list={["localized-page", { active: lang === "zh" }]} data-lang-panel={lang} data-page-key={pageKey}>
        <section class="hero-map page-shell">
          <div class="hero-copy">
            <p class="overline">{page.kicker}</p>
            <h1 class="display-title">{page.title}</h1>
            <p class="body-copy">{page.lead}</p>
            <div class="hero-actions">
              <a class="outline-action" href={actionHref}>{page.primaryAction}</a>
              <a class="text-link" href={secondaryHref}>{page.secondaryAction}<span aria-hidden="true">↗</span></a>
            </div>
          </div>

          <div class="hero-coordinate" aria-hidden="true">
            <span>43.2220° N</span>
            <span>76.8512° E</span>
            <span>ALMATY / KZ</span>
          </div>
        </section>

        <section class="network-section page-shell" aria-labelledby={`network-${lang}-${pageKey}`}>
          <div class="network-heading">
            <h2 id={`network-${lang}-${pageKey}`}>{ui.network}</h2>
            <p>{ui.networkNote}</p>
          </div>

          <figure class="route-atlas">
            <svg viewBox="0 0 1200 610" role="img" aria-labelledby={`map-title-${lang}-${pageKey} map-desc-${lang}-${pageKey}`}>
              <title id={`map-title-${lang}-${pageKey}`}>{ui.network}</title>
              <desc id={`map-desc-${lang}-${pageKey}`}>{ui.networkNote}</desc>

              <g class="atlas-grid" aria-hidden="true">
                <path d="M70 115H1130" />
                <path d="M70 305H1130" />
                <path d="M70 495H1130" />
                <path d="M170 65V545" />
                <path d="M430 65V545" />
                <path d="M690 65V545" />
                <path d="M950 65V545" />
              </g>

              <path class="route-line route-line-primary" d="M150 397 C265 345 310 250 435 279 S595 355 673 300" />
              <path class="route-line route-line-water" d="M673 300 C760 235 825 225 885 270" />
              <path class="route-line route-line-primary" d="M885 270 C980 285 1025 210 1095 164" />
              <path class="route-line route-line-fallback" d="M435 279 C570 185 730 155 885 270" />

              <g class="route-caption" aria-hidden="true">
                <text x="292" y="336">{ui.rail}</text>
                <text x="745" y="222">{ui.sea}</text>
                <text x="980" y="242">{ui.road}</text>
              </g>

              <a href="/services/" class="atlas-node" aria-label={ui.cities[0]}>
                <circle cx="150" cy="397" r="10" />
                <circle class="node-ring" cx="150" cy="397" r="25" />
                <text x="116" y="447">{ui.cities[0]}</text>
              </a>
              <a href="/about/" class="atlas-node atlas-node-major" aria-label={ui.cities[1]}>
                <circle cx="435" cy="279" r="13" />
                <circle class="node-ring" cx="435" cy="279" r="34" />
                <text x="390" y="232">{ui.cities[1]}</text>
              </a>
              <a href="/routes/" class="atlas-node" aria-label={ui.cities[2]}>
                <circle cx="673" cy="300" r="10" />
                <circle class="node-ring" cx="673" cy="300" r="25" />
                <text x="628" y="350">{ui.cities[2]}</text>
              </a>
              <a href="/routes/" class="atlas-node" aria-label={ui.cities[3]}>
                <circle cx="885" cy="270" r="10" />
                <circle class="node-ring" cx="885" cy="270" r="25" />
                <text x="855" y="320">{ui.cities[3]}</text>
              </a>
              <a href="/industries/" class="atlas-node" aria-label={ui.cities[4]}>
                <circle cx="1095" cy="164" r="10" />
                <circle class="node-ring" cx="1095" cy="164" r="25" />
                <text x="1002" y="130">{ui.cities[4]}</text>
              </a>
            </svg>

            <figcaption>
              <span>{page.visualLabel}</span>
              <a class="text-link" href="/routes/">{ui.routeAction}<span aria-hidden="true">↗</span></a>
            </figcaption>
          </figure>

          <div class="mobile-route-list" aria-label={ui.network}>
            {ui.cities.map((city, index) => (
              <a href={index === 1 ? "/about/" : index > 1 ? "/routes/" : "/services/"}>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <strong>{city}</strong>
                <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </section>

        <section class="trust-section page-shell">
          <header class="trust-heading">
            <p class="overline">{ui.proof}</p>
            <h2 class="section-title">{trust.title}</h2>
            <p class="body-copy">{trust.text}</p>
          </header>

          <div class="trust-ledger">
            {trust.items.map((item, index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <strong>{item.value}</strong>
                <div>
                  <h3>{item.label}</h3>
                  <p>{item.note}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="capability-section page-shell">
          <div class="section-heading-row">
            <h2 class="section-title">{ui.capabilities}</h2>
            <p>{page.sectionsTitle}</p>
          </div>
          <div class="capability-list">
            {page.sections.map((section) => (
              <article>
                <h3>{section.title}</h3>
                <p>{section.text}</p>
                <ul>
                  {section.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>
              </article>
            ))}
          </div>
        </section>

        <section class="stat-strip page-shell" aria-label={page.sectionsTitle}>
          {page.stats.map((stat) => (
            <div>
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
            </div>
          ))}
        </section>

        <section class="scenario-section page-shell">
          <div class="section-heading-row scenario-heading">
            <h2 class="section-title">{ui.operating}</h2>
            <p>{page.panelsTitle}</p>
          </div>

          <div class="scenario-board" data-switchboard>
            <div class="tabs" role="tablist" aria-label={page.panelsTitle}>
              {page.panels.map((panel, index) => (
                <button
                  class:list={["tab-button", { active: index === 0 }]}
                  type="button"
                  role="tab"
                  id={`tab-${lang}-${pageKey}-${index}`}
                  aria-controls={`panel-${lang}-${pageKey}-${index}`}
                  aria-selected={index === 0 ? "true" : "false"}
                  tabindex={index === 0 ? 0 : -1}
                  data-panel-tab={index}
                >
                  {panel.label}
                </button>
              ))}
            </div>

            <div class="scenario-panels">
              {page.panels.map((panel, index) => (
                <article
                  class:list={{ active: index === 0 }}
                  role="tabpanel"
                  id={`panel-${lang}-${pageKey}-${index}`}
                  aria-labelledby={`tab-${lang}-${pageKey}-${index}`}
                  data-panel-content={index}
                  hidden={index !== 0}
                >
                  <span>{String(index + 1).padStart(2, "0")}</span>
                  <h3>{panel.title}</h3>
                  <p>{panel.text}</p>
                  <ul>{panel.points.map((point) => <li>{point}</li>)}</ul>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="process-section page-shell">
          <div class="section-heading-row">
            <h2 class="section-title">{page.timelineTitle}</h2>
            <p>{page.ctaText}</p>
          </div>
          <ol class="process-list">
            {page.timeline.map((item) => (
              <li>
                <span>{item.step}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </li>
            ))}
          </ol>
        </section>

        <section class="closing-cta page-shell">
          <h2>{page.ctaTitle}</h2>
          <div>
            <p>{page.ctaText}</p>
            <a class="outline-action" href={`mailto:${CONTACT_INFO.business}`}>{page.ctaButton}</a>
          </div>
        </section>
      </article>
    );
  })}
</div>

<script>
  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;
    const tab = target.closest<HTMLButtonElement>("[data-panel-tab]");
    if (!tab) return;
    const board = tab.closest<HTMLElement>("[data-switchboard]");
    const index = tab.dataset.panelTab;
    board?.querySelectorAll<HTMLButtonElement>("[data-panel-tab]").forEach((button) => {
      const active = button.dataset.panelTab === index;
      button.classList.toggle("active", active);
      button.setAttribute("aria-selected", String(active));
      button.tabIndex = active ? 0 : -1;
    });
    board?.querySelectorAll<HTMLElement>("[data-panel-content]").forEach((panel) => {
      const active = panel.dataset.panelContent === index;
      panel.classList.toggle("active", active);
      panel.hidden = !active;
    });
  });
</script>

<style>
  .site-page {
    background: var(--color-paper);
  }

  .hero-map {
    display: grid;
    min-height: calc(100svh - var(--banner-height));
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: var(--space-2xl);
    padding-block: var(--space-3xl) var(--space-4xl);
    border-bottom: var(--rule-hair) solid var(--color-rule);
  }

  .hero-copy {
    display: grid;
    max-width: 78rem;
    gap: var(--space-lg);
  }

  .hero-copy .body-copy {
    max-width: 55ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-lg);
    margin-top: var(--space-sm);
  }

  .hero-coordinate {
    display: grid;
    justify-items: end;
    gap: var(--space-2xs);
    color: var(--color-muted);
    font-size: var(--text-xs);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.08em;
  }

  .network-section,
  .trust-section,
  .capability-section,
  .scenario-section,
  .process-section {
    padding-block: var(--space-4xl);
  }

  .network-heading,
  .section-heading-row {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
    align-items: end;
    gap: var(--space-2xl);
    margin-bottom: var(--space-2xl);
  }

  .network-heading h2 {
    max-width: 20ch;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 5rem);
    font-style: normal;
    font-weight: 400;
    letter-spacing: -0.035em;
    line-height: 0.96;
  }

  .network-heading p,
  .section-heading-row > p {
    max-width: 45ch;
    margin: 0;
    color: var(--color-muted);
  }

  .route-atlas {
    margin: 0;
    border-block: var(--rule-hair) solid var(--color-rule);
  }

  .route-atlas svg {
    width: 100%;
    min-height: 31rem;
  }

  .atlas-grid path {
    fill: none;
    stroke: var(--color-rule);
    stroke-width: 1;
  }

  .route-line {
    fill: none;
    stroke-linecap: round;
  }

  .route-line-primary {
    stroke: var(--color-ink);
    stroke-width: 3;
  }

  .route-line-water {
    stroke: var(--color-accent);
    stroke-width: 4;
    stroke-dasharray: 8 9;
  }

  .route-line-fallback {
    stroke: var(--color-faint);
    stroke-width: 1.5;
    stroke-dasharray: 4 8;
  }

  .route-caption text,
  .atlas-node text {
    fill: var(--color-muted);
    font-family: var(--font-body);
    font-size: 15px;
    letter-spacing: 0.03em;
  }

  .atlas-node circle:first-of-type {
    fill: var(--color-accent);
    stroke: var(--color-paper);
    stroke-width: 4;
  }

  .atlas-node-major circle:first-of-type {
    fill: var(--color-ink);
  }

  .node-ring {
    fill: transparent;
    stroke: var(--color-accent);
    stroke-width: 1;
    opacity: 0.45;
    transform-box: fill-box;
    transform-origin: center;
    transition: opacity var(--dur-medium) var(--ease-out), transform var(--dur-medium) var(--ease-out);
  }

  .atlas-node:hover .node-ring,
  .atlas-node:focus-visible .node-ring {
    opacity: 1;
    transform: scale(1.18);
  }

  .atlas-node:focus-visible {
    outline: none;
  }

  .atlas-node:focus-visible circle:first-of-type {
    stroke: var(--color-focus);
  }

  .route-atlas figcaption {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding-block: var(--space-md);
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .mobile-route-list {
    display: none;
  }

  .trust-section {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
    gap: var(--space-4xl);
    border-top: var(--rule-hair) solid var(--color-rule);
  }

  .trust-heading {
    position: sticky;
    top: calc(var(--banner-height) + var(--space-xl));
    align-self: start;
    display: grid;
    gap: var(--space-lg);
  }

  .trust-ledger {
    border-top: var(--rule-hair) solid var(--color-rule);
  }

  .trust-ledger article {
    display: grid;
    grid-template-columns: 3rem minmax(8rem, 0.45fr) minmax(0, 1fr);
    align-items: start;
    gap: var(--space-lg);
    padding-block: var(--space-xl);
    border-bottom: var(--rule-hair) solid var(--color-rule);
  }

  .trust-ledger article > span {
    color: var(--color-faint);
    font-size: var(--text-xs);
  }

  .trust-ledger strong {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 500;
    line-height: 1;
  }

  .trust-ledger h3,
  .trust-ledger p,
  .capability-list h3,
  .capability-list p,
  .scenario-panels h3,
  .scenario-panels p,
  .process-list h3,
  .process-list p {
    margin: 0;
  }

  .trust-ledger h3 {
    font-size: var(--text-base);
    font-weight: 500;
  }

  .trust-ledger p {
    margin-top: var(--space-xs);
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .capability-section {
    background: var(--color-paper-soft);
    box-shadow: 0 0 0 100vmax var(--color-paper-soft);
    clip-path: inset(0 -100vmax);
  }

  .capability-list {
    border-top: var(--rule-hair) solid var(--color-ink);
  }

  .capability-list article {
    display: grid;
    grid-template-columns: minmax(12rem, 0.8fr) minmax(0, 1.2fr) minmax(12rem, 0.65fr);
    gap: var(--space-xl);
    padding-block: var(--space-xl);
    border-bottom: var(--rule-hair) solid var(--color-rule);
  }

  .capability-list h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-style: normal;
    font-weight: 500;
    line-height: 1.05;
  }

  .capability-list p {
    color: var(--color-ink-soft);
  }

  .capability-list ul,
  .scenario-panels ul {
    display: flex;
    flex-wrap: wrap;
    align-content: flex-start;
    gap: var(--space-xs) var(--space-md);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .capability-list li,
  .scenario-panels li {
    color: var(--color-muted);
    font-size: var(--text-sm);
    white-space: nowrap;
  }

  .capability-list li::before,
  .scenario-panels li::before {
    content: "— ";
    color: var(--color-accent);
  }

  .stat-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-block: var(--rule-hair) solid var(--color-rule);
  }

  .stat-strip > div {
    display: grid;
    min-width: 0;
    gap: var(--space-xs);
    padding: var(--space-xl);
    border-right: var(--rule-hair) solid var(--color-rule);
  }

  .stat-strip > div:last-child {
    border-right: 0;
  }

  .stat-strip strong {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 4.5rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1;
    overflow-wrap: anywhere;
  }

  .stat-strip span {
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .scenario-board {
    display: grid;
    grid-template-columns: minmax(10rem, 0.35fr) minmax(0, 1fr);
    gap: var(--space-3xl);
  }

  .tabs {
    display: grid;
    align-content: start;
  }

  .tab-button {
    justify-content: space-between;
    padding-inline: 0;
    border-bottom: var(--rule-hair) solid var(--color-rule);
    border-radius: 0;
    color: var(--color-muted);
  }

  .tab-button.active {
    color: var(--color-ink);
  }

  .tab-button.active::after {
    content: "↗";
  }

  .scenario-panels article {
    display: none;
    min-height: 24rem;
    align-content: end;
    grid-template-columns: 4rem minmax(0, 1.2fr) minmax(14rem, 0.8fr);
    gap: var(--space-xl);
    padding: var(--space-3xl);
    background: var(--color-ink);
    color: var(--color-paper);
  }

  .scenario-panels article.active {
    display: grid;
  }

  .scenario-panels article > span {
    color: var(--color-faint);
    font-size: var(--text-xs);
  }

  .scenario-panels h3 {
    max-width: 18ch;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4.5vw, 5rem);
    font-style: normal;
    color: var(--color-paper);
    font-weight: 400;
    letter-spacing: -0.035em;
    line-height: 0.95;
    overflow-wrap: anywhere;
  }

  .scenario-panels p {
    color: var(--color-faint);
  }

  .scenario-panels ul {
    grid-column: 3;
  }

  .process-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 0;
    padding: 0;
    border-top: var(--rule-hair) solid var(--color-ink);
    list-style: none;
  }

  .process-list li {
    display: grid;
    align-content: start;
    gap: var(--space-lg);
    padding: var(--space-xl);
    border-right: var(--rule-hair) solid var(--color-rule);
  }

  .process-list li:last-child {
    border-right: 0;
  }

  .process-list span {
    color: var(--color-accent-deep);
    font-size: var(--text-xs);
  }

  .process-list h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-style: normal;
    font-weight: 500;
  }

  .process-list p {
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .closing-cta {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
    align-items: end;
    gap: var(--space-3xl);
    padding-block: var(--space-4xl);
    border-top: var(--rule-hair) solid var(--color-ink);
  }

  .closing-cta h2 {
    max-width: 18ch;
    margin: 0;
    font-family: var(--font-display);
