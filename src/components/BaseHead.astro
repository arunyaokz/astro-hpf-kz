---
import { getCollection } from "astro:content";
import { LANGS, pagePath, type CorePage, type Lang } from "../site-v2";

interface Props {
  title: string;
  description: string;
  lang: Lang;
  page: CorePage;
  image?: string;
}

const { title, description, lang, page, image = "/og-hpf-kz.svg" } = Astro.props;
const canonicalURL = new URL(pagePath(lang, page), Astro.site);
const facts = await getCollection("facts");
const verified = new Map(facts.filter((fact) => fact.data.verified).map((fact) => [fact.id, fact.data.value]));
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": ["Organization", "LogisticsBusiness"],
  name: verified.get("public_identity") ?? "HPF.kz",
  url: new URL(pagePath("en", "home"), Astro.site).toString(),
  email: verified.get("business_email"),
  address: verified.get("operating_city") ? {
    "@type": "PostalAddress",
    addressLocality: "Almaty",
    addressCountry: "KZ",
  } : undefined,
  areaServed: ["China", "Kazakhstan", "Europe"],
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonicalURL} />
{LANGS.map((code) => <link rel="alternate" hreflang={code === "zh" ? "zh-CN" : code} href={new URL(pagePath(code, page), Astro.site)} />)}
<link rel="alternate" hreflang="x-default" href={new URL(pagePath("en", page), Astro.site)} />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content="index,follow,max-image-preview:large" />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="HPF.kz" />
<meta property="og:locale" content={lang === "zh" ? "zh_CN" : lang === "ru" ? "ru_RU" : "en_US"} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.site)} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, Astro.site)} />

<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
