---
import { CONTACT_COPY, pagePath, type Lang } from "../site-v2";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const page = CONTACT_COPY[lang];
---

<article class="contact-page">
  <section class="contact-hero shell">
    <div>
      <p class="eyebrow">{page.eyebrow}</p>
      <h1 class="display">{page.title}</h1>
      <p class="lead">{page.lead}</p>
    </div>
    <aside class="contact-hero__visual">
      <img src="/images/corporate/hero-contact-request.webp" alt={lang === "zh" ? "根据货运需求制作公路运输方案" : lang === "ru" ? "Подготовка автотранспортного плана по заявке на груз" : "Preparing a road freight plan from a shipment request"} width="1024" height="1536" fetchpriority="high" />
      <div class="contact-hero__details">
        <p class="eyebrow">Data boundary</p>
        <h2>{page.asideTitle}</h2>
        <p>{page.asideText}</p>
        <dl><div><dt>{page.emailLabel}</dt><dd><a href="mailto:bd@hpf.kz">bd@hpf.kz</a></dd></div></dl>
        <small>{page.responseNote}</small>
      </div>
    </aside>
  </section>

  <section class="form-section shell">
    <form data-enquiry-form data-required-message={page.fields.required} data-mail-subject="HPF.kz freight enquiry">
      <div class="form-grid">
        <label>{page.fields.name}<span aria-hidden="true">*</span><input name="name" autocomplete="name" required /></label>
        <label>{page.fields.company}<input name="company" autocomplete="organization" /></label>
        <label>{page.fields.email}<span aria-hidden="true">*</span><input type="email" name="email" autocomplete="email" required /></label>
        <label>{page.fields.phone}<input type="tel" name="phone" autocomplete="tel" /></label>
        <label class="wide">{page.fields.cargo}<span aria-hidden="true">*</span><textarea name="cargo" rows="3" required></textarea></label>
        <label>{page.fields.origin}<span aria-hidden="true">*</span><input name="origin" required /></label>
        <label>{page.fields.destination}<span aria-hidden="true">*</span><input name="destination" required /></label>
        <label class="wide">{page.fields.window}<input name="window" /></label>
        <label class="wide">{page.fields.message}<textarea name="message" rows="4"></textarea></label>
      </div>
      <label class="consent"><input type="checkbox" name="consent" required /><span>{page.fields.consent} <a href={pagePath(lang, "privacy")}>{lang === "zh" ? "查看政策" : lang === "ru" ? "Открыть уведомление" : "Read notice"}</a></span></label>
      <div class="form-actions"><button class="button button--primary" type="submit">{page.fields.submit}</button><p data-form-status aria-live="polite"></p></div>
    </form>
  </section>
</article>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-enquiry-form]");
  const status = form?.querySelector<HTMLElement>("[data-form-status]");
  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      if (status) status.textContent = form.dataset.requiredMessage ?? "Complete the required fields.";
      return;
    }
    const data = new FormData(form);
    const lines = Array.from(data.entries())
      .filter(([key]) => key !== "consent")
      .map(([key, value]) => `${key}: ${String(value).trim() || "—"}`);
    const subject = form.dataset.mailSubject ?? "HPF.kz freight enquiry";
    window.location.href = `mailto:bd@hpf.kz?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(lines.join("\n"))}`;
  });
</script>

<style>
  .contact-page { overflow:hidden; background:var(--paper); }
  .contact-hero { display:grid; grid-template-columns:minmax(0,1.1fr) minmax(20rem,.7fr); gap:clamp(3rem,8vw,8rem); align-items:center; min-height:38rem; padding-block:clamp(5rem,9vw,8rem); background:var(--ink); box-shadow:0 0 0 100vmax var(--ink); clip-path:inset(0 -100vmax); }
  .contact-hero > div { display:grid; gap:1.25rem; }
  .contact-hero .eyebrow { color:var(--electric); }
  .contact-hero .display { max-width: 11ch; }
  .contact-hero .display { color:#fff; }
  .contact-hero .lead { color:var(--muted-on-dark); }
  .contact-hero__visual { position:relative; display:grid; min-height:32rem; overflow:hidden; isolation:isolate; border:1px solid rgba(255,255,255,.1); border-radius:1.6rem; background:var(--ink-2); box-shadow:0 28px 90px rgba(0,0,0,.28); }
  .contact-hero__visual::after { position:absolute; z-index:-1; inset:0; background:linear-gradient(180deg,rgba(15,8,48,.02) 24%,rgba(15,8,48,.9)); content:""; }
  .contact-hero__visual > img { position:absolute; z-index:-2; width:100%; height:100%; object-fit:cover; object-position:54% center; filter:saturate(.72) contrast(1.04); }
  .contact-hero__details { align-self:end; display:grid; gap:1.25rem; padding:1.6rem; }
  .contact-hero__details h2 { color:#fff; font-size:1.35rem; }
  .contact-hero__details p,.contact-hero__details small { color:var(--muted-on-dark); }
  .contact-hero__details dl { margin:0; }
  .contact-hero__details dl div { display:flex; justify-content:space-between; gap:var(--space-2); padding-block:.9rem; border-block:1px solid rgba(255,255,255,.1); }
  .contact-hero__details dt { color:rgba(255,255,255,.42); }
  .contact-hero__details dd { margin:0; color:var(--electric); }
  .form-section { padding-block:clamp(5rem,9vw,8rem); }
  form { max-width:64rem; margin-inline:auto; padding:clamp(1.25rem,4vw,3rem); border:1px solid var(--line); border-radius:2rem; background:#fff; box-shadow:0 28px 80px rgba(37,23,91,.08); }
  .form-grid { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: var(--space-2); }
  label { display:grid; gap:.55rem; color:var(--text); font-size:.82rem; font-weight:700; }
  label > span[aria-hidden="true"] { display: inline; margin-inline-start: .25rem; color: var(--red); }
  label.wide { grid-column: 1 / -1; }
  input,textarea { width:100%; border:1px solid rgba(24,18,47,.15); border-radius:.9rem; background:#f8f7fc; color:var(--text); padding:.85rem 1rem; transition:border-color 180ms var(--ease-out),background 180ms var(--ease-out),box-shadow 180ms var(--ease-out); }
  input { min-height:3.25rem; }
  input:focus,textarea:focus { border-color:var(--violet); background:#fff; outline:0; box-shadow:0 0 0 4px rgba(91,62,228,.1); }
  textarea { resize: vertical; }
  .consent { grid-template-columns: auto 1fr; gap: 0.75rem; align-items: start; margin-block-start: var(--space-3); color: var(--mut); font-weight: 400; }
  .consent input { width: 1.125rem; min-height: 1.125rem; margin-block-start: 0.25rem; }
  .consent a { color: var(--cobalt-700); text-decoration: underline; }
  .form-actions { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2); margin-block-start: var(--space-3); }
  .form-actions p { color: var(--red); font-size: 0.875rem; }
  @media (max-width:52rem) { .contact-hero { grid-template-columns:1fr; } }
  @media (max-width: 38rem) { .form-grid { grid-template-columns: 1fr; } label.wide { grid-column: auto; } }
</style>
