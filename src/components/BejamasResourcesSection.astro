---
import { TRANSLATIONS } from '../consts';

const t = TRANSLATIONS.zh;
---

<section class="bejamas-section bejamas-bg-gradient">
  <div class="bejamas-container">
    <div class="bejamas-section-header bejamas-text-center">
      <h2 class="bejamas-title-2xl bejamas-heading">{t.resourcesTitle}</h2>
      <p class="bejamas-subtitle bejamas-mt-2">专业的物流知识和实用工具</p>
    </div>
    
    <div class="bejamas-resources-grid">
      <div class="bejamas-resource-card">
        <div class="bejamas-resource-icon bejamas-bg-blue-100">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 14L12 17M12 10L12 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M7 3.33782C8.47087 2.48697 10.1786 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 10.1786 2.48697 8.47087 3.33782 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">海关清关指南</h3>
        <p class="bejamas-text-base bejamas-text-muted">哈萨克斯坦海关最新政策和清关流程详解</p>
        <div class="bejamas-resource-meta">
          <span class="bejamas-resource-type">PDF文档</span>
          <span class="bejamas-resource-size">2.3 MB</span>
        </div>
        <a href="#" class="bejamas-button bejamas-button-outline bejamas-mt-4">下载指南</a>
      </div>
      
      <div class="bejamas-resource-card">
        <div class="bejamas-resource-icon bejamas-bg-green-100">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 12L11 14L15 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M12 3V12M12 21V12M12 12L21 12M12 12L3 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">运费计算器</h3>
        <p class="bejamas-text-base bejamas-text-muted">实时计算中国到哈萨克斯坦的运输费用</p>
        <div class="bejamas-resource-meta">
          <span class="bejamas-resource-type">在线工具</span>
          <span class="bejamas-resource-size">免费使用</span>
        </div>
        <a href="#" class="bejamas-button bejamas-button-outline bejamas-mt-4">开始计算</a>
      </div>
      
      <div class="bejamas-resource-card">
        <div class="bejamas-resource-icon bejamas-bg-purple-100">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 16C14.2091 16 16 14.2091 16 12C16 9.79086 14.2091 8 12 8C9.79086 8 8 9.79086 8 12C8 14.2091 9.79086 16 12 16Z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 2V4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M12 20V22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M4.93 4.93L6.34 6.34" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M17.66 17.66L19.07 19.07" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M2 12H4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M20 12H22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M6.34 17.66L4.93 19.07" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M19.07 4.93L17.66 6.34" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">运输时间表</h3>
        <p class="bejamas-text-base bejamas-text-muted">各线路标准运输时间和时效参考</p>
        <div class="bejamas-resource-meta">
          <span class="bejamas-resource-type">数据表格</span>
          <span class="bejamas-resource-size">实时更新</span>
        </div>
        <a href="#" class="bejamas-button bejamas-button-outline bejamas-mt-4">查看详情</a>
      </div>
      
      <div class="bejamas-resource-card">
        <div class="bejamas-resource-icon bejamas-bg-yellow-100">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 16C14.2091 16 16 14.2091 16 12C16 9.79086 14.2091 8 12 8C9.79086 8 8 9.79086 8 12C8 14.2091 9.79086 16 12 16Z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 13V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">包装规范</h3>
        <p class="bejamas-text-base bejamas-text-muted">不同货物类型的专业包装要求和标准</p>
        <div class="bejamas-resource-meta">
          <span class="bejamas-resource-type">技术文档</span>
          <span class="bejamas-resource-size">1.8 MB</span>
        </div>
        <a href="#" class="bejamas-button bejamas-button-outline bejamas-mt-4">下载规范</a>
      </div>
      
      <div class="bejamas-resource-card">
        <div class="bejamas-resource-icon bejamas-bg-red-100">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 21C16.9706 21 21 16.9706 21 12C21 7.02944 16.9706 3 12 3C7.02944 3 3 7.02944 3 12C3 16.9706 7.02944 21 12 21Z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 8V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M12 16H12.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">保险指南</h3>
        <p class="bejamas-text-base bejamas-text-muted">货物运输保险的选择和理赔流程</p>
        <div class="bejamas-resource-meta">
          <span class="bejamas-resource-type">指南文档</span>
          <span class="bejamas-resource-size">1.2 MB</span>
        </div>
        <a href="#" class="bejamas-button bejamas-button-outline bejamas-mt-4">阅读指南</a>
      </div>
      
      <div class="bejamas-resource-card">
        <div class="bejamas-resource-icon bejamas-bg-gray-100">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 2H6C4.89543 2 4 2.89543 4 4V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V8L14 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M14 2V8H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M16 13H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M16 17H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M10 9H9H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 class="bejamas-title-lg">合同模板</h3>
        <p class="bejamas-text-base bejamas-text-muted">标准运输合同和协议模板下载</p>
        <div class="bejamas-resource-meta">
          <span class="bejamas-resource-type">法律文档</span>
          <span class="bejamas-resource-size">Word格式</span>
        </div>
        <a href="#" class="bejamas-button bejamas-button-outline bejamas-mt-4">下载模板</a>
      </div>
    </div>
    
    <div class="bejamas-resources-cta bejamas-text-center bejamas-mt-12">
      <h3 class="bejamas-title-xl">需要更多专业支持？</h3>
      <p class="bejamas-text-lg bejamas-text-muted bejamas-mt-2">我们的专业团队随时为您提供一对一的咨询服务</p>
      <div class="bejamas-cta-actions bejamas-mt-6">
        <a href="#contact" class="bejamas-button bejamas-button-primary bejamas-mr-4">预约咨询</a>
        <a href="tel:+77771234567" class="bejamas-button bejamas-button-outline">电话联系</a>
      </div>
    </div>
  </div>
</section>

<style>
  .bejamas-resources-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--bejamas-space-6);
  }
  
  @media (min-width: 640px) {
    .bejamas-resources-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .bejamas-resources-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .bejamas-resource-card {
    background-color: var(--bejamas-color-surface);
    border: 1px solid var(--bejamas-color-border);
    border-radius: var(--bejamas-radius-xl);
    padding: var(--bejamas-space-6);
    transition: all var(--bejamas-transition-base);
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  
  .bejamas-resource-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--bejamas-shadow-lg);
  }
  
  .bejamas-resource-icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--bejamas-radius-lg);
    color: var(--bejamas-color-accent);
    margin-bottom: var(--bejamas-space-4);
  }
  
  .bejamas-resource-meta {
    display: flex;
    justify-content: space-between;
    margin-top: var(--bejamas-space-4);
    margin-bottom: var(--bejamas-space-4);
  }
  
  .bejamas-resource-type {
    background-color: var(--bejamas-color-bg-muted);
    color: var(--bejamas-color-text-muted);
    padding: var(--bejamas-space-1) var(--bejamas-space-3);
    border-radius: var(--bejamas-radius-full);
    font-size: var(--bejamas-text-xs);
    font-weight: 500;
  }
  
  .bejamas-resource-size {
    color: var(--bejamas-color-text-muted);
    font-size: var(--bejamas-text-xs);
  }
  
  .bejamas-resources-cta {
    background-color: var(--bejamas-color-surface);
    border: 1px solid var(--bejamas-color-border);
    border-radius: var(--bejamas-radius-xl);
    padding: var(--bejamas-space-8);
  }
  
  .bejamas-cta-actions {
    display: flex;
    justify-content: center;
    gap: var(--bejamas-space-4);
    flex-wrap: wrap;
  }
  
  /* Color variants */
  .bejamas-bg-blue-100 {
    background-color: rgba(59, 130, 246, 0.1);
    color: var(--bejamas-color-blue-600);
  }
  
  .bejamas-bg-green-100 {
    background-color: rgba(16, 185, 129, 0.1);
    color: var(--bejamas-color-green-600);
  }
  
  .bejamas-bg-purple-100 {
    background-color: rgba(139, 92, 246, 0.1);
    color: var(--bejamas-color-purple-600);
  }
  
  .bejamas-bg-yellow-100 {
    background-color: rgba(245, 158, 11, 0.1);
    color: var(--bejamas-color-yellow-600);
  }
  
  .bejamas-bg-red-100 {
    background-color: rgba(239, 68, 68, 0.1);
    color: var(--bejamas-color-red-600);
  }
  
  .bejamas-bg-gray-100 {
    background-color: rgba(156, 163, 175, 0.1);
    color: var(--bejamas-color-gray-600);
  }
  
  /* Spacing utilities */
  .bejamas-mt-2 { margin-top: var(--bejamas-space-2); }
  .bejamas-mt-4 { margin-top: var(--bejamas-space-4); }
  .bejamas-mt-6 { margin-top: var(--bejamas-space-6); }
  .bejamas-mt-12 { margin-top: var(--bejamas-space-12); }
  .bejamas-mr-4 { margin-right: var(--bejamas-space-4); }
  
  .bejamas-text-center { text-align: center; }
  
  .bejamas-bg-gradient {
    background: linear-gradient(135deg, 
      var(--bejamas-color-bg) 0%, 
      var(--bejamas-color-surface) 100%);
  }
</style>