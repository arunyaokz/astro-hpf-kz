---
import { getCollection, render, type CollectionEntry } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("news", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"news">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<SiteLayout title={`${entry.data.title} | HPF.kz`} description={entry.data.description} active="news">
  <article class="news-article page-shell">
    <header>
      <a class="text-link" href="/news/">← News</a>
      <p class="overline">{entry.data.category} / {entry.data.verificationStatus}</p>
      <h1 class="display-title">{entry.data.title}</h1>
      <p class="body-copy">{entry.data.description}</p>
      <div class="article-meta">
        <time datetime={entry.data.pubDate.toISOString()}>{entry.data.pubDate.toLocaleDateString()}</time>
        <span>{entry.data.author}</span>
      </div>
    </header>

    <div class="article-layout">
      <aside>
        <span>AI maintained</span>
        <span>{entry.data.lang.toUpperCase()}</span>
        <span>{entry.data.translationKey}</span>
      </aside>
      <div class="prose"><Content /></div>
    </div>

    {entry.data.sourceUrls.length > 0 && (
      <footer class="sources">
        <h2>Sources</h2>
        <ol>
          {entry.data.sourceUrls.map((url) => <li><a class="text-link" href={url} rel="noreferrer">{url}</a></li>)}
        </ol>
      </footer>
    )}
  </article>
</SiteLayout>

<style>
  .news-article {
    padding-block: var(--space-3xl) var(--space-5xl);
  }

  .news-article > header {
    display: grid;
    min-height: 70svh;
    align-content: end;
    gap: var(--space-lg);
    padding-bottom: var(--space-3xl);
    border-bottom: var(--rule-hair) solid var(--color-ink);
  }

  .news-article .display-title {
    max-width: 15ch;
  }

  .news-article .text-link {
    justify-self: start;
  }

  .article-meta {
    display: flex;
    gap: var(--space-xl);
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(10rem, 0.35fr) minmax(0, 1fr);
    gap: var(--space-3xl);
    padding-block: var(--space-3xl);
  }

  .article-layout aside {
    display: grid;
    align-content: start;
    gap: var(--space-xs);
    color: var(--color-muted);
    font-size: var(--text-xs);
  }

  .prose {
    max-width: 68ch;
    font-size: var(--text-lg);
  }

  .prose :global(h2),
  .prose :global(h3) {
    margin: var(--space-2xl) 0 var(--space-md);
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 500;
    line-height: 1.05;
  }

  .prose :global(h2) {
    font-size: var(--text-3xl);
  }

  .prose :global(p),
  .prose :global(li) {
    color: var(--color-ink-soft);
  }

  .sources {
    padding-top: var(--space-xl);
    border-top: var(--rule-hair) solid var(--color-rule);
  }

  .sources h2 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-style: normal;
    font-weight: 500;
  }

  .sources li {
    margin-block: var(--space-sm);
  }

  @media (max-width: 47.99rem) {
    .news-article {
      padding-block: var(--space-xl) var(--space-4xl);
    }

    .article-layout {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--space-xl);
    }

    .article-layout aside {
      grid-template-columns: repeat(3, auto);
      justify-content: start;
      gap: var(--space-md);
    }
  }
</style>
